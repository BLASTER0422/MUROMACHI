    generous: { aggression: 0.2, fear: 0.5, greed: 0.1, loyalty: 0.7 },
    cruel: { aggression: 0.8, fear: 0.3, greed: 0.6, loyalty: 0.2 },
    kind: { aggression: 0.2, fear: 0.4, greed: 0.2, loyalty: 0.8 },
    sly: { aggression: 0.5, fear: 0.4, greed: 0.7, loyalty: 0.3 }
};
const TRAIT_NAMES = Object.keys(PERSONALITY_TRAITS);

// ---------- NPC CLASS ----------
class NPC {
    constructor(data = {}) {
        this.npcId = data.npcId || uuid();
        this.name = data.name || generateNPCName(data.gender || 'male');
        this.age = data.age || (Math.floor(Math.random() * 40) + 18);
        this.gender = data.gender || (Math.random() < 0.6 ? 'male' : 'female');
        this.profession = data.profession || 'farmer';
        this.category = PROFESSIONS[this.profession]?.category || 'commoner';
        this.faction = data.faction || null;
        this.locationId = data.locationId || 'shimosa_kogane';
        this.alive = data.alive !== undefined ? data.alive : true;
        this.birthYear = data.birthYear || (WorldClock.currentClock?.year || 1380) - this.age;
        this.birthMonth = data.birthMonth || (Math.floor(Math.random() * 12) + 1);

        this.traits = data.traits || this.randomTraits();
        this.aggression = this.traits.aggression;
        this.fear = this.traits.fear;
        this.greed = this.traits.greed;
        this.loyalty = this.traits.loyalty;

        this.relationships = data.relationships || {};
        this.schedule = data.schedule || this.defaultSchedule();
        this.inventory = data.inventory || [];
        this.wealth = data.wealth !== undefined ? data.wealth : (PROFESSIONS[this.profession]?.wages * 5 + Math.floor(Math.random() * 20));
        this.health = data.health || 100;
        this.combatSkill = data.combatSkill || this.deriveCombatSkill();
        this.equippedWeapon = data.equippedWeapon || null;

        this.hired = data.hired || false;
        this.employerId = data.employerId || null;
        this.hireMode = data.hireMode || null;
        this.wage = data.wage || 0;
        this.hireTask = data.hireTask || null;

        this.isCaptive = data.isCaptive || false;
        this.captorId = data.captorId || null;
        this.captureDate = data.captureDate || null;

        this.dialogueMemory = data.dialogueMemory || [];
    }

    randomTraits() {
        const traitName = TRAIT_NAMES[Math.floor(Math.random() * TRAIT_NAMES.length)];
        const baseTrait = PERSONALITY_TRAITS[traitName];
        return {
            aggression: Math.min(1, Math.max(0, baseTrait.aggression + (Math.random() * 0.3 - 0.15))),
            fear: Math.min(1, Math.max(0, baseTrait.fear + (Math.random() * 0.3 - 0.15))),
            greed: Math.min(1, Math.max(0, baseTrait.greed + (Math.random() * 0.3 - 0.15))),
            loyalty: Math.min(1, Math.max(0, baseTrait.loyalty + (Math.random() * 0.3 - 0.15)))
        };
    }

    deriveCombatSkill() {
        const prof = this.profession;
        if (prof === 'samurai') return 6 + Math.floor(Math.random() * 4);
        if (prof === 'ronin') return 5 + Math.floor(Math.random() * 5);
        if (prof === 'ashigaru') return 4 + Math.floor(Math.random() * 4);
        if (prof === 'bandit') return 3 + Math.floor(Math.random() * 4);
        if (prof === 'scout') return 4 + Math.floor(Math.random() * 3);
        if (prof === 'monk' || prof === 'priest') return 2 + Math.floor(Math.random() * 4);
        return Math.floor(Math.random() * 4);
    }

    defaultSchedule() {
        const cat = this.category;
        if (cat === 'commoner' && this.profession === 'farmer') {
            return {
                sleep: { start: 20, end: 5, location: 'home', activity: 'sleep' },
                morningWork: { start: 5, end: 12, location: 'fields', activity: 'work' },
                midday: { start: 12, end: 13, location: 'home', activity: 'eat' },
                afternoonWork: { start: 13, end: 18, location: 'fields', activity: 'work' },
                evening: { start: 18, end: 20, location: 'village_square', activity: 'social' }
            };
        } else if (cat === 'merchant' || cat === 'artisan') {
            return {
                sleep: { start: 21, end: 6, location: 'home', activity: 'sleep' },
                work: { start: 6, end: 12, location: 'shop', activity: 'work' },
                break: { start: 12, end: 13, location: 'home', activity: 'eat' },
                work2: { start: 13, end: 18, location: 'shop', activity: 'work' },
                social: { start: 18, end: 21, location: 'market', activity: 'social' }
            };
        } else if (cat === 'religious') {
            return {
                sleep: { start: 21, end: 5, location: 'temple', activity: 'sleep' },
                prayer: { start: 5, end: 7, location: 'temple', activity: 'worship' },
                service: { start: 7, end: 12, location: 'temple', activity: 'work' },
                rest: { start: 12, end: 13, location: 'temple', activity: 'eat' },
                afternoon: { start: 13, end: 18, location: 'village', activity: 'social' },
                evening: { start: 18, end: 21, location: 'temple', activity: 'worship' }
            };
        } else if (cat === 'samurai') {
            return {
                sleep: { start: 22, end: 5, location: 'barracks', activity: 'sleep' },
                training: { start: 5, end: 8, location: 'training_ground', activity: 'train' },
                duty: { start: 8, end: 12, location: 'castle', activity: 'work' },
                lunch: { start: 12, end: 13, location: 'barracks', activity: 'eat' },
                duty2: { start: 13, end: 18, location: 'castle', activity: 'work' },
                leisure: { start: 18, end: 22, location: 'inn', activity: 'social' }
            };
        } else {
            return {
                sleep: { start: 22, end: 6, location: 'camp', activity: 'sleep' },
                roam: { start: 6, end: 20, location: 'wilderness', activity: 'roam' },
                evening: { start: 20, end: 22, location: 'tavern', activity: 'social' }
            };
        }
    }

    getCurrentActivity(hour) {
        for (const [key, block] of Object.entries(this.schedule)) {
            if (hour >= block.start && hour < block.end) return block;
            if (block.start > block.end) {
                if (hour >= block.start || hour < block.end) return block;
            }
        }
        return { location: 'unknown', activity: 'idle' };
    }

    getCurrentLocation(hour) {
        return this.getCurrentActivity(hour).location;
    }

    adjustRelationship(npcId, amount) {
        if (!this.relationships[npcId]) this.relationships[npcId] = 0;
        this.relationships[npcId] = Math.max(-100, Math.min(100, this.relationships[npcId] + amount));
    }

    getRelationship(npcId) {
        return this.relationships[npcId] || 0;
    }

    toJSON() {
        return {
            npcId: this.npcId, name: this.name, age: this.age, gender: this.gender, profession: this.profession,
            category: this.category, faction: this.faction, locationId: this.locationId, alive: this.alive,
            birthYear: this.birthYear, birthMonth: this.birthMonth, traits: this.traits, relationships: this.relationships,
            schedule: this.schedule, inventory: this.inventory, wealth: this.wealth, health: this.health,
            combatSkill: this.combatSkill, equippedWeapon: this.equippedWeapon,
            hired: this.hired, employerId: this.employerId, hireMode: this.hireMode, wage: this.wage, hireTask: this.hireTask,
            isCaptive: this.isCaptive, captorId: this.captorId, captureDate: this.captureDate,
            dialogueMemory: this.dialogueMemory
        };
    }

    static fromJSON(data) {
        return new NPC(data);
    }
}

// ---------- NPC DATABASE OPERATIONS ----------
async function saveNPC(npc) {
    if (!db) return;
    const tx = db.transaction(STORES.npcs, 'readwrite');
    const store = tx.objectStore(STORES.npcs);
    store.put(npc.toJSON());
    await new Promise(res => { tx.oncomplete = res; });
}

async function loadNPC(npcId) {
    if (!db) return null;
    const tx = db.transaction(STORES.npcs, 'readonly');
    const store = tx.objectStore(STORES.npcs);
    const data = await new Promise(res => { const req = store.get(npcId); req.onsuccess = () => res(req.result); });
    return data ? NPC.fromJSON(data) : null;
}

async function loadNPCsAtLocation(locationId) {
    if (!db) return [];
    const tx = db.transaction(STORES.npcs, 'readonly');
    const store = tx.objectStore(STORES.npcs);
    const index = store.index('location');
    const npcsData = await new Promise(res => { const req = index.getAll(locationId); req.onsuccess = () => res(req.result); });
    return (npcsData || []).map(d => NPC.fromJSON(d));
}

async function getAllNPCs() {
    if (!db) return [];
    const tx = db.transaction(STORES.npcs, 'readonly');
    const store = tx.objectStore(STORES.npcs);
    const all = await new Promise(res => { const req = store.getAll(); req.onsuccess = () => res(req.result); });
    return (all || []).map(d => NPC.fromJSON(d));
}

// ---------- NPC GENERATION FOR LOCATIONS ----------
async function generateNPCsForLocation(locationId, count = 5) {
    const existing = await loadNPCsAtLocation(locationId);
    if (existing.length >= count) return existing;
    const needed = count - existing.length;
    const loc = await getLocationById(locationId);
    if (!loc) return existing;

    const isTown = loc.type === 'town' || loc.type === 'city';
    const isVillage = loc.type === 'village';
    const profList = Object.keys(PROFESSIONS);
    const npcs = [];

    for (let i = 0; i < needed; i++) {
        let prof;
        if (isTown) {
            prof = profList.filter(p => PROFESSIONS[p].baseLocation !== 'wilderness')[Math.floor(Math.random() * profList.length)];
        } else if (isVillage) {
            prof = ['farmer', 'peasant', 'woodcutter', 'fisherman', 'charcoalBurner', 'priest', 'headman'][Math.floor(Math.random() * 7)];
        } else {
            prof = 'bandit';
        }
        const npc = new NPC({
            locationId: locationId,
            profession: prof,
            faction: loc.province === 'shimosa' ? 'Chiba' : (loc.province === 'hitachi' ? 'Satake' : null)
        });
        npcs.push(npc);
    }

    if (db) {
        const tx = db.transaction(STORES.npcs, 'readwrite');
        const store = tx.objectStore(STORES.npcs);
        for (const npc of npcs) { store.put(npc.toJSON()); }
        await new Promise(res => { tx.oncomplete = res; });
    }

    return [...existing, ...npcs];
}

// ---------- NPC INTERACTION: SEE PEOPLE ----------
async function actionSeePeople() {
    const player = GameState.player;
    if (!player) return;
    const currentLoc = GameState.currentLocation;
    if (!currentLoc) return;

    const npcs = await generateNPCsForLocation(currentLoc.locationId, currentLoc.type === 'city' ? 8 : (currentLoc.type === 'town' ? 5 : 3));
    let peopleHTML = `<h3>👥 People of ${currentLoc.name}</h3>`;
    if (npcs.length === 0) {
        peopleHTML += '<p>No one is around at this hour.</p>';
    } else {
        peopleHTML += '<ul style="list-style:none; padding-left:0;">';
        for (const npc of npcs) {
            if (!npc.alive) continue;
            const rel = npc.getRelationship(player.id);
            const relSymbol = rel > 30 ? '🤝' : (rel < -30 ? '😠' : '😐');
            peopleHTML += `<li style="margin-bottom:8px; padding:6px; border-bottom:1px solid var(--border);">
                <strong>${npc.name}</strong> <small>(${npc.profession})</small> ${relSymbol}
                <br><small>${npc.age} | ${npc.gender}</small>
                <br><button onclick="talkToNPC('${npc.npcId}')">💬 Talk</button>
            </li>`;
        }
        peopleHTML += '</ul>';
    }
    document.getElementById('main-content').innerHTML += peopleHTML;
    document.getElementById('action-panel').innerHTML = '<button onclick="showGameScreen()">← Back</button>';
    await TurnEngine.performAction('dialogue');
}

// ---------- TALK TO NPC ----------
async function talkToNPC(npcId) {
    const player = GameState.player;
    if (!player) return;
    const npc = await loadNPC(npcId);
    if (!npc) return;

    const dialogue = GME.generateNPCDialogue(npc, {
        name: player.name,
        season: WorldClock.getCurrentContext().season,
        timeOfDay: WorldClock.getCurrentContext().timeOfDay,
        weather: GameState.currentWeather || 'clear'
    }, 'greeting');

    if (!npc.dialogueMemory) npc.dialogueMemory = [];
    npc.dialogueMemory.push(dialogue);
    if (npc.dialogueMemory.length > 10) npc.dialogueMemory.shift();
    await saveNPC(npc);

    npc.adjustRelationship(player.id, 1);
    await saveNPC(npc);

    const main = document.getElementById('main-content');
    main.innerHTML += `<div class="panel" style="margin-top:10px;">
        <strong>${npc.name} (${npc.profession}):</strong>
        <p style="font-style:italic; margin:8px 0;">"${dialogue}"</p>
        <button onclick="showGameScreen()">Continue</button>
    </div>`;
    document.getElementById('log-panel').innerHTML += `\n[${npc.name}]: "${dialogue}"`;

    await TurnEngine.performAction('dialogue');
}


