// ---------- CRIME SYSTEM ----------
const CrimeSystem = {
    pendingReports: [],

    async recordCrime(crimeType, player, location, witnesses = []) {
        if (!player || !location) return;
        const severityMap = {
            insult: 1,
            threaten: 3,
            assault: 5,
            kidnap: 8,
            murder: 10
        };
        const severity = severityMap[crimeType] || 1;
        const province = location.province || 'shimosa';

        let reported = false;
        for (const witness of witnesses) {
            if (!witness.alive) continue;
            const rel = witness.getRelationship(player.id);
            const fear = witness.fear;
            const reportChance = Math.max(0.05, (1 - (rel + 100) / 200) * (1 - fear * 0.5));
            if (Math.random() < reportChance) {
                reported = true;
                break;
            }
        }

        const crimeRecord = {
            recordId: uuid(),
            crimeType,
            severity,
            province,
            locationId: location.locationId,
            perpetratorId: player.id,
            perpetratorName: player.name,
            turn: WorldClock.getCurrentContext().year * 360 + WorldClock.getCurrentContext().day,
            reported,
            bounty: severity * 10,
            resolved: false
        };

        if (db) {
            const tx = db.transaction(STORES.crimeRecords, 'readwrite');
            tx.objectStore(STORES.crimeRecords).add(crimeRecord);
            await new Promise(res => { tx.oncomplete = res; });
        }

        player.reputation.general -= severity;
        if (!player.bounty) player.bounty = 0;
        player.bounty += crimeRecord.bounty;

        if (reported) {
            GameState.log(`Witnesses report your crime to the local magistrate. A bounty of ${crimeRecord.bounty} mon is placed on your head.`);
        } else {
            GameState.log('The crime goes unreported... for now.');
        }

        await savePlayerToDB(player);
    },

    async getWitnesses(locationId, hour) {
        const npcs = await loadNPCsAtLocation(locationId);
        const witnessCandidates = npcs.filter(n => n.alive && n.getCurrentActivity(hour).location !== 'sleep');
        return witnessCandidates.filter(() => Math.random() < 0.5);
    },

    async handleAggressiveAction(actionType, targetNPC) {
        const player = GameState.player;
        if (!player) return;
        const loc = GameState.currentLocation;
        if (!loc || loc.type === 'wilderness') return;

        const hour = WorldClock.currentClock.hour;
        const witnesses = await this.getWitnesses(loc.locationId, hour);
        await this.recordCrime(actionType, player, loc, witnesses);
    }
};

