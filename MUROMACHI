const INJURY_TYPES = {
    minor_wound: { name: 'Minor Wound', severity: 20, healBase: 3, treatmentItem: 'item_bandages' },
    deep_cut: { name: 'Deep Cut', severity: 40, healBase: 1, treatmentItem: 'item_healing_poultice' },
    broken_bone: { name: 'Broken Bone', severity: 60, healBase: 0.5, treatmentItem: 'item_splint' },
    infection: { name: 'Infection', severity: 35, healBase: 1, treatmentItem: 'item_medicine_herb' },
    fever: { name: 'Fever', severity: 45, healBase: 1, treatmentItem: 'item_medicine_herb' },
    frostbite: { name: 'Frostbite', severity: 30, healBase: 1, treatmentItem: 'item_bandages' },
    poison: { name: 'Poison', severity: 50, healBase: 2, treatmentItem: 'item_antidote' }
};

function addInjury(player, injuryTypeKey, source = 'unknown') {
    if (!player.injuries) player.injuries = [];
    const injuryDef = INJURY_TYPES[injuryTypeKey];
    if (!injuryDef) return;
    const existing = player.injuries.find(i => i.type === injuryTypeKey);
    if (existing) {
        existing.severity = Math.min(100, existing.severity + injuryDef.severity * 0.5);
    } else {
        player.injuries.push({
            type: injuryTypeKey,
            severity: injuryDef.severity,
            date: WorldClock.getCurrentContext().year * 360 + WorldClock.getCurrentContext().day,
            treated: false
        });
    }
    GameState.log(`You suffer ${injuryDef.name}.`);
}

function applyInjuryEffects(player) {
    if (!player.injuries || player.injuries.length === 0) return;
    let totalPenalty = 0;
    for (const injury of player.injuries) {
        totalPenalty += injury.severity / 100 * 5;
    }
    player.adjustHealth(-Math.floor(totalPenalty / 2));
    for (const injury of player.injuries) {
        const def = INJURY_TYPES[injury.type];
        if (!def) continue;
        const healAmount = def.healBase * 0.1;
        injury.severity = Math.max(0, injury.severity - healAmount);
    }
    player.injuries = player.injuries.filter(i => i.severity > 0);
}

async function treatInjury(injuryIndex) {
    const player = GameState.player;
    if (!player || !player.injuries || injuryIndex < 0 || injuryIndex >= player.injuries.length) return;
    const injury = player.injuries[injuryIndex];
    const def = INJURY_TYPES[injury.type];
    if (!def) return;
    const treatmentItemId = def.treatmentItem;
    if (!player.hasItem(treatmentItemId, 1)) {
        alert(`You need a ${treatmentItemId} to treat this.`);
        return;
    }
    const medicalSkill = player.getSkillRank('igaku');
    const successChance = 30 + medicalSkill * 8;
    if (Math.random() * 100 < successChance) {
        player.removeItem(treatmentItemId, 1);
        injury.severity = Math.max(0, injury.severity - 30);
        injury.treated = true;
        GameState.log(`Treatment successful. ${def.name} improves.`);
    } else {
        GameState.log('Your treatment attempt fails.');
    }
    if (injury.severity <= 0) {
        player.injuries.splice(injuryIndex, 1);
        GameState.log('The injury has fully healed.');
    }
    await savePlayerToDB(player);
}

