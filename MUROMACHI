// ---------- ECONOMY ENGINE ----------
const EconomyEngine = {
    priceCache: {},

    async getPrice(locationId, goodKey) {
        const cacheKey = `${locationId}_${goodKey}`;
        if (this.priceCache[cacheKey] !== undefined) return this.priceCache[cacheKey];

        if (!db) {
            const baseGood = MARKET_GOODS[goodKey];
            return baseGood ? baseGood.basePrice : 5;
        }

        const tx = db.transaction(STORES.economy, 'readonly');
        const store = tx.objectStore(STORES.economy);
        const econData = await new Promise(res => {
            const req = store.get(locationId);
            req.onsuccess = () => res(req.result);
        });

        if (econData && econData.goods && econData.goods[goodKey]) {
            const good = econData.goods[goodKey];
            const currentPrice = Math.round(good.basePrice * (1 + (good.demand || 0) * 0.5 - (good.supply || 0) * 0.001));
            this.priceCache[cacheKey] = Math.max(1, currentPrice);
            return this.priceCache[cacheKey];
        }
        const baseGood = MARKET_GOODS[goodKey];
        this.priceCache[cacheKey] = baseGood ? baseGood.basePrice : 5;
        return this.priceCache[cacheKey];
    },

    async getSupply(locationId, goodKey) {
        if (!db) return 100;
        const tx = db.transaction(STORES.economy, 'readonly');
        const store = tx.objectStore(STORES.economy);
        const econData = await new Promise(res => {
            const req = store.get(locationId);
            req.onsuccess = () => res(req.result);
        });
        return (econData && econData.goods && econData.goods[goodKey]) ? econData.goods[goodKey].supply : 100;
    },

    async updatePrices(locationId) {
        if (!db) return;
        const tx = db.transaction(STORES.economy, 'readwrite');
        const store = tx.objectStore(STORES.economy);
        let econData = await new Promise(res => {
            const req = store.get(locationId);
            req.onsuccess = () => res(req.result);
        });

        if (!econData) {
            econData = { locationId, goods: {} };
            for (const [key, def] of Object.entries(MARKET_GOODS)) {
                econData.goods[key] = {
                    basePrice: def.basePrice,
                    supply: 100 + Math.floor(Math.random() * 200),
                    demand: 0.5 + Math.random() * 0.5
                };
            }
        }

        const season = WorldClock.getCurrentContext().season;
        const events = GameState.activeEvents || [];

        for (const [key, def] of Object.entries(MARKET_GOODS)) {
            if (!econData.goods[key]) {
                econData.goods[key] = { basePrice: def.basePrice, supply: 100 + Math.floor(Math.random() * 200), demand: 0.5 + Math.random() * 0.5 };
            }
            const good = econData.goods[key];

            if (def.category === 'food' && def.perishable) {
                if (season === 'autumn') good.supply += 20;
                if (season === 'winter') good.supply -= 15;
                if (season === 'spring') good.demand += 0.1;
            }
            if (key === 'sake' && season === 'winter') good.demand += 0.2;
            if (key === 'charcoal' && season === 'winter') good.demand += 0.3;
            if (key === 'timber' && season === 'spring') good.demand += 0.15;

            for (const event of events) {
                if (event.type === 'drought' || event.type === 'flood') {
                    if (def.category === 'food') good.supply -= 30;
                }
                if (event.type === 'war' || event.type === 'bandit_raid') {
                    if (def.category === 'weapon' || key === 'iron_ingot') good.demand += 0.4;
                }
                if (event.type === 'merchant_caravan') {
                    good.supply += 25;
                }
            }

            good.supply += Math.floor(Math.random() * 10 - 5);
            good.demand += (Math.random() * 0.1 - 0.05);
            good.supply = Math.max(5, Math.min(500, good.supply));
            good.demand = Math.max(0.1, Math.min(2.0, good.demand));
        }

        store.put(econData);
        await new Promise(res => { tx.oncomplete = res; });

        for (const key of Object.keys(this.priceCache)) {
            if (key.startsWith(locationId + '_')) delete this.priceCache[key];
        }
    },

    getPriceTrend(basePrice, currentPrice) {
        const ratio = currentPrice / basePrice;
        if (ratio > 1.3) return '📈 High';
        if (ratio > 1.1) return '↗️ Above average';
        if (ratio < 0.7) return '📉 Low';
        if (ratio < 0.9) return '↘️ Below average';
        return '➡️ Stable';
    }
};

