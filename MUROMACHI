async function buyGood(goodKey, quantity) {
    const player = GameState.player;
    if (!player) return;
    const locId = GameState.currentLocation?.locationId;
    if (!locId) return;

    const price = await EconomyEngine.getPrice(locId, goodKey);
    const totalCost = price * quantity;
    if (player.wealth < totalCost) {
        alert('Not enough mon.');
        return;
    }

    const supply = await EconomyEngine.getSupply(locId, goodKey);
    if (supply < quantity) {
        alert('Not enough stock.');
        return;
    }

    const goodDef = MARKET_GOODS[goodKey];
    const addedWeight = (goodDef?.weight || 1) * quantity;
    if (player.getCurrentWeight() + addedWeight > player.getMaxCarry()) {
        alert('You cannot carry that much.');
        return;
    }

    player.wealth -= totalCost;
    const itemId = 'item_' + goodKey;
    const existingItem = await GameState.getItemDef(itemId);
    if (!existingItem || (existingItem.weight === 1 && existingItem.name === itemId)) {
        if (db) {
            const tx = db.transaction(STORES.items, 'readwrite');
            const itemStore = tx.objectStore(STORES.items);
            itemStore.put({
                itemId: itemId,
                name: goodDef.name,
                category: goodDef.category,
                perishable: goodDef.perishable,
                weight: goodDef.weight,
                baseValue: goodDef.basePrice
            });
            await new Promise(res => { tx.oncomplete = res; });
        }
    }
    player.addItem(itemId, quantity);

    if (db) {
        const tx = db.transaction(STORES.economy, 'readwrite');
        const econStore = tx.objectStore(STORES.economy);
        const econData = await new Promise(res => {
            const req = econStore.get(locId);
            req.onsuccess = () => res(req.result);
        });
        if (econData && econData.goods && econData.goods[goodKey]) {
            econData.goods[goodKey].supply = Math.max(0, econData.goods[goodKey].supply - quantity);
            econStore.put(econData);
        }
        await new Promise(res => { tx.oncomplete = res; });
    }

    delete EconomyEngine.priceCache[`${locId}_${goodKey}`];

    GameState.log(`Bought ${quantity}x ${goodDef.name} for ${totalCost} mon.`);
    await savePlayerToDB(player);
    actionVisitMarket();
}

async function sellGood(goodKey, quantity) {
    const player = GameState.player;
    if (!player) return;
    const locId = GameState.currentLocation?.locationId;
    if (!locId) return;

    const itemId = 'item_' + goodKey;
    if (!player.hasItem(itemId, quantity)) {
        alert('You don\'t have that many to sell.');
        return;
    }

    const price = await EconomyEngine.getPrice(locId, goodKey);
    const sellPrice = Math.floor(price * 0.7);
    const totalEarnings = sellPrice * quantity;

    player.removeItem(itemId, quantity);
    player.wealth += totalEarnings;

    if (db) {
        const tx = db.transaction(STORES.economy, 'readwrite');
        const econStore = tx.objectStore(STORES.economy);
        const econData = await new Promise(res => {
            const req = econStore.get(locId);
            req.onsuccess = () => res(req.result);
        });
        if (econData && econData.goods && econData.goods[goodKey]) {
            econData.goods[goodKey].supply += quantity;
            econStore.put(econData);
        }
        await new Promise(res => { tx.oncomplete = res; });
    }

    delete EconomyEngine.priceCache[`${locId}_${goodKey}`];

    const goodDef = MARKET_GOODS[goodKey];
    GameState.log(`Sold ${quantity}x ${goodDef.name} for ${totalEarnings} mon.`);
    await savePlayerToDB(player);
    actionVisitMarket();
}

