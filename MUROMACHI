// ==================== CHUNK 12: PLAYER SETTLEMENT — FOUNDING, BUILDING, MANAGEMENT ====================

class PlayerSettlement {
    constructor(data = {}) {
        this.settlementId = data.settlementId || uuid();
        this.name = data.name || 'New Mura';
        this.founderId = data.founderId || (GameState.player ? GameState.player.id : null);
        this.locationId = data.locationId || null;
        this.province = data.province || 'shimosa';
        this.foundedYear = data.foundedYear || WorldClock.currentClock.year;
        this.foundedMonth = data.foundedMonth || WorldClock.currentClock.month;

        this.residents = data.residents || [];
        this.buildings = data.buildings || [];

        this.resources = data.resources || {
            timber: 0,
            stone: 0,
            iron_ingot: 0,
            food: 0,
            water: 0,
            charcoal: 0,
            gold: 0
        };

        this.defenseRating = data.defenseRating || 0;
        this.wallLevel = data.wallLevel || 0;
        this.guards = data.guards || [];

        this.taxRate = data.taxRate || 0.1;
        this.morale = data.morale || 60;
        this.activeEvents = data.activeEvents || [];
    }

    getMaxPopulation() {
        let capacity = 5;
        for (const b of this.buildings) {
            switch (b.buildingType) {
                case 'hovel': capacity += 2; break;
                case 'farmhouse': capacity += 5; break;
                case 'barracks': capacity += 8; break;
                case 'inn': capacity += 10; break;
                default: break;
            }
        }
        return capacity;
    }

    getCurrentPopulation() {
        return this.residents.length;
    }

    async calculateDailyProduction() {
        const production = {
            food: 0,
            timber: 0,
            stone: 0,
            iron_ingot: 0,
            charcoal: 0,
            gold: 0
        };

        const residentNPCs = [];
        for (const npcId of this.residents) {
            const npc = await loadNPC(npcId);
            if (npc && npc.alive) residentNPCs.push(npc);
        }

        for (const b of this.buildings) {
            switch (b.buildingType) {
                case 'farmhouse': {
                    const workers = residentNPCs.filter(n => b.assignedWorkers && b.assignedWorkers.includes(n.npcId));
                    for (const w of workers) {
                        const skill = (w.getSkillRank ? (w.getSkillRank('suiden') + w.getSkillRank('hatake')) / 2 : 1);
                        production.food += 3 + skill * 2;
                    }
                    break;
                }
                case 'workshop': {
                    const workers = residentNPCs.filter(n => b.assignedWorkers && b.assignedWorkers.includes(n.npcId));
                    for (const w of workers) {
                        const craftSkill = Math.max(
                            w.getSkillRank ? w.getSkillRank('kaji') : 0,
                            w.getSkillRank ? w.getSkillRank('daiku') : 0,
                            w.getSkillRank ? w.getSkillRank('senshoku') : 0
                        );
                        production.gold += 5 + craftSkill * 3;
                        if (w.profession === 'blacksmith') production.iron_ingot += 1;
                        if (w.profession === 'carpenter') production.timber += 2;
                    }
                    break;
                }
                case 'lumber_mill': {
                    const workers = residentNPCs.filter(n => b.assignedWorkers && b.assignedWorkers.includes(n.npcId));
                    for (const w of workers) {
                        const skill = w.getSkillRank ? w.getSkillRank('sanrin') : 0;
                        production.timber += 4 + skill * 3;
                    }
                    break;
                }
                case 'mine': {
                    const workers = residentNPCs.filter(n => b.assignedWorkers && b.assignedWorkers.includes(n.npcId));
                    for (const w of workers) {
                        const skill = w.getSkillRank ? w.getSkillRank('ishiku') : 0;
                        production.stone += 3;
                        if (Math.random() < 0.3) production.iron_ingot += 1;
                    }
                    break;
                }
                case 'shrine': {
                    this.morale = Math.min(100, this.morale + 1);
                    break;
                }
                case 'inn': {
                    production.gold += 10;
                    break;
                }
                case 'market_square': {
                    production.gold += 8;
                    break;
                }
                default: break;
            }
        }

        const unassigned = residentNPCs.filter(n => {
            return !this.buildings.some(b => b.assignedWorkers && b.assignedWorkers.includes(n.npcId));
        });
        production.food += unassigned.length * 1;

        const moraleMod = this.morale / 100;
        for (const key of Object.keys(production)) {
            production[key] = Math.floor(production[key] * moraleMod);
        }

        return production;
    }

    async dailyConsumption() {
        const pop = this.getCurrentPopulation();
        const foodNeeded = pop * 2;
        if (this.resources.food >= foodNeeded) {
            this.resources.food -= foodNeeded;
        } else {
            const deficit = foodNeeded - this.resources.food;
            this.resources.food = 0;
            this.morale -= 10 + deficit;
            if (this.morale < 20 && pop > 0) {
                const deaths = Math.ceil(pop * 0.1);
                GameState.log(`Famine strikes ${this.name}! ${deaths} residents perish.`);
                for (let i = 0; i < deaths && this.residents.length > 0; i++) {
                    const victimId = this.residents.pop();
                    const victim = await loadNPC(victimId);
                    if (victim) { victim.alive = false; await saveNPC(victim); }
                }
                this.morale = Math.max(0, this.morale - 20);
            }
        }
    }

    async tickDay() {
        const prod = await this.calculateDailyProduction();
        for (const [key, val] of Object.entries(prod)) {
            this.resources[key] = (this.resources[key] || 0) + val;
        }
        await this.dailyConsumption();

        if (this.activeEvents.length > 0) {
            for (const event of this.activeEvents) {
                if (event.type === 'bandit_raid') {
                    this.resources.gold = Math.max(0, this.resources.gold - 20);
                    this.morale -= 5;
                    GameState.log(`Bandits raid ${this.name}, stealing gold!`);
                }
            }
            this.activeEvents = [];
        }

        const taxIncome = Math.floor(this.resources.gold * this.taxRate);
        this.resources.gold -= taxIncome;
        if (this.founderId === GameState.player?.id) {
            GameState.player.wealth += taxIncome;
            GameState.log(`Taxes from ${this.name}: +${taxIncome} mon.`);
        }

        await saveSettlement(this);
    }

    addResident(npcId) {
        if (!this.residents.includes(npcId)) {
            this.residents.push(npcId);
        }
    }

    removeResident(npcId) {
        this.residents = this.residents.filter(id => id !== npcId);
        for (const b of this.buildings) {
            if (b.assignedWorkers) b.assignedWorkers = b.assignedWorkers.filter(id => id !== npcId);
        }
    }

    toJSON() {
        return {
            settlementId: this.settlementId,
            name: this.name,
            founderId: this.founderId,
            locationId: this.locationId,
            province: this.province,
            foundedYear: this.foundedYear,
            foundedMonth: this.foundedMonth,
            residents: this.residents,
            buildings: this.buildings,
            resources: this.resources,
            defenseRating: this.defenseRating,
            wallLevel: this.wallLevel,
            guards: this.guards,
            taxRate: this.taxRate,
            morale: this.morale,
            activeEvents: this.activeEvents
        };
    }

    static fromJSON(data) {
        return new PlayerSettlement(data);
    }
}

// ---------- SETTLEMENT DB OPERATIONS ----------
async function saveSettlement(settlement) {
    if (!db) return;
    const tx = db.transaction(STORES.settlements, 'readwrite');
    const store = tx.objectStore(STORES.settlements);
    store.put(settlement.toJSON());
    await new Promise(res => { tx.oncomplete = res; });
}

async function loadSettlement(settlementId) {
    if (!db) return null;
    const tx = db.transaction(STORES.settlements, 'readonly');
    const store = tx.objectStore(STORES.settlements);
    const data = await new Promise(res => {
        const req = store.get(settlementId);
        req.onsuccess = () => res(req.result);
    });
    return data ? PlayerSettlement.fromJSON(data) : null;
}

async function getPlayerSettlements(playerId) {
    if (!db) return [];
    const tx = db.transaction(STORES.settlements, 'readonly');
    const store = tx.objectStore(STORES.settlements);
    const all = await new Promise(res => {
        const req = store.getAll();
        req.onsuccess = () => res(req.result);
    });
    return (all || []).filter(s => s.founderId === playerId).map(s => PlayerSettlement.fromJSON(s));
}

// ---------- FOUND A SETTLEMENT ----------
async function actionFoundSettlement() {
    const player = GameState.player;
    if (!player) return;
    const currentLoc = GameState.currentLocation;
    if (!currentLoc || (currentLoc.type !== 'wilderness' && currentLoc.type !== 'village' && currentLoc.type !== 'town')) {
        alert('You can only found a settlement in the wilderness or outskirts.');
        return;
    }
    if (player.followers.length < 3) {
        alert('You need at least 3 followers (retainers or companions) to found a settlement.');
        return;
    }
    const needed = { item_timber: 10, item_stone: 5 };
    for (const [itemId, qty] of Object.entries(needed)) {
        if (!player.hasItem(itemId, qty)) {
            alert(`Missing materials: ${itemId} x${qty}`);
            return;
        }
    }

    const name = prompt('Name your settlement:', 'Mura');
    if (!name) return;

    for (const [itemId, qty] of Object.entries(needed)) {
        player.removeItem(itemId, qty);
    }

    const settlement = new PlayerSettlement({
        name: name,
        founderId: player.id,
        locationId: currentLoc.locationId,
        province: currentLoc.province || 'shimosa',
        foundedYear: WorldClock.currentClock.year,
        foundedMonth: WorldClock.currentClock.month,
        resources: { timber: 5, stone: 3, food: 20, water: 30, charcoal: 2, iron_ingot: 0, gold: 0 }
    });

    for (let i = 0; i < 3; i++) {
        const npcId = player.followers[i];
        const npc = await loadNPC(npcId);
        if (npc) {
            settlement.addResident(npcId);
            npc.locationId = settlement.settlementId;
            npc.hired = false;
            npc.employerId = null;
            await saveNPC(npc);
        }
    }
    player.followers = player.followers.filter((_, idx) => idx >= 3);

    settlement.buildings.push({
        buildingType: 'hovel',
        name: 'Founder\'s Hut',
        level: 1,
        condition: 100,
        assignedWorkers: [],
        builtYear: WorldClock.currentClock.year,
        builtMonth: WorldClock.currentClock.month
    });
    settlement.buildings.push({
        buildingType: 'hovel',
        name: 'Settler\'s Hut',
        level: 1,
        condition: 100,
        assignedWorkers: [],
        builtYear: WorldClock.currentClock.year,
        builtMonth: WorldClock.currentClock.month
    });

    await saveSettlement(settlement);
    await savePlayerToDB(player);

    GameState.log(`You found the settlement of ${name}! May it grow and prosper.`);

    const locEntry = {
        locationId: settlement.settlementId,
        name: settlement.name,
        type: 'settlement',
        province: settlement.province,
        terrainTags: currentLoc.terrainTags || ['plains'],
        description: `A fledgling village founded by ${player.name}.`,
        population: settlement.getCurrentPopulation(),
        connectedLocations: [currentLoc.locationId],
        parentLocation: settlement.province
    };
    if (db) {
        const tx = db.transaction(STORES.locations, 'readwrite');
        const locStore = tx.objectStore(STORES.locations);
        locStore.put(locEntry);
        await new Promise(res => { tx.oncomplete = res; });
    }

    GameState.currentLocation = locEntry;
    player.locationId = settlement.settlementId;
    document.getElementById('location-display').textContent = settlement.name;
    showGameScreen();
}

