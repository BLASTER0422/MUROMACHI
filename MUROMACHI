            </div>
            <div class="flex-row" style="margin-top:6px;">
                <button onclick="CombatEngine.attemptFlee()" style="color:var(--gold);">🏃 Flee</button>
                <button onclick="CombatEngine.acceptYield()" id="btn-accept-yield" style="color:var(--gold); display:none;">🤝 Accept Surrender</button>
            </div>
        `;
    },

    async playerAction(stance) {
        const combat = this.activeCombat;
        if (!combat || combat.status !== 'ongoing') return;

        combat.round++;
        const player = combat.player;
        const enemy = combat.enemy;
        const stanceData = COMBAT_STANCES[stance];

        const weaponSkill = getWeaponSkill(player.equipped?.weapon);
        const playerSkillRank = weaponSkill ? player.getSkillRank(weaponSkill) : player.getSkillRank('jujutsu');
        const playerEffectiveSkill = playerSkillRank * 5;

        if (stance === 'parley') {
            await this.handleParley();
            return;
        }

        const playerAttackBase = playerEffectiveSkill * stanceData.attackMod;
        const playerAttackRoll = Math.random() * 100 + playerAttackBase;
        const enemyDefenseBase = enemy.combatSkill * 3;
        const enemyDefenseRoll = enemyDefenseBase + 30;

        let playerDamage = 0;
        if (playerAttackRoll > enemyDefenseRoll) {
            const baseDamage = 8 + Math.floor(Math.random() * 12) + Math.floor(playerEffectiveSkill / 2);
            playerDamage = Math.round(baseDamage * stanceData.damageMod);
            enemy.health = Math.max(0, enemy.health - playerDamage);
            combat.enemyMorale -= 8 + Math.floor(Math.random() * 6);

            const hitNarration = GME.generateNarration('combat_hit', {
                enemy: enemy.name,
                weapon: player.equipped?.weapon || 'strike',
                ground: combat.location.terrainTags?.[0] || 'earth',
                season: WorldClock.getCurrentContext().season
            });
            combat.log.push(hitNarration);
        } else {
            combat.enemyMorale -= 2;
            const missNarration = GME.generateNarration('combat_miss', {
                enemy: enemy.name,
                weapon: player.equipped?.weapon || 'weapon',
                ground: combat.location.terrainTags?.[0] || 'earth'
            });
            combat.log.push(missNarration);
        }

        if (enemy.health > 0) {
            const enemyAttackBase = enemy.combatSkill * 5;
            const enemyAttackRoll = Math.random() * 100 + enemyAttackBase;
            const playerDefenseBase = playerEffectiveSkill * stanceData.defenseMod;
            const playerDefenseRoll = playerDefenseBase + 25;

            if (enemyAttackRoll > playerDefenseRoll) {
                const enemyDamage = 6 + Math.floor(Math.random() * 14) + Math.floor(enemy.combatSkill / 2);
                player.health = Math.max(0, player.health - enemyDamage);
                combat.playerMorale -= 10;

                const enemyHitNarration = GME.generateNarration('combat_enemyHit', {
                    enemy: enemy.name,
                    enemyWeapon: enemy.equippedWeapon || 'weapon',
                    ground: combat.location.terrainTags?.[0] || 'earth'
                });
                combat.log.push(enemyHitNarration);
            } else {
                combat.playerMorale = Math.min(100, combat.playerMorale + 2);
                const enemyMissNarration = GME.generateNarration('combat_enemyMiss', {
                    enemy: enemy.name,
                    ground: combat.location.terrainTags?.[0] || 'earth'
                });
                combat.log.push(enemyMissNarration);
            }
        }

        combat.playerFatigue += stanceData.fatigueCost;
        player.fatigue = Math.min(100, player.fatigue + stanceData.fatigueCost);
        combat.enemyFatigue += 3 + Math.floor(Math.random() * 3);

        combat.playerMorale = Math.min(100, Math.max(0, combat.playerMorale + (stanceData.moraleCost || 0)));
        if (enemy.health < 30 && combat.enemyMorale > 20) combat.enemyMorale -= 5;
        if (player.health < 30 && combat.playerMorale > 20) combat.playerMorale -= 5;

        if (enemy.health < 50 && combat.enemyMorale < 40) {
            const yieldChance = getYieldChance(enemy.category);
            if (Math.random() < yieldChance) {
                await this.enemyOffersYield();
                return;
            }
        }

        if (enemy.fear > 0.6 && combat.enemyMorale < 30 && enemy.health < 60 && Math.random() < 0.25) {
            await this.enemyFlees();
            return;
        }

        if (player.health <= 0) {
            await this.endCombat('player_dead');
            return;
        }

        if (enemy.health <= 0) {
            await this.endCombat('enemy_dead');
            return;
        }

        if (combat.round > 25) {
            await this.endCombat('stalemate');
            return;
        }

        await saveNPC(enemy);
        await savePlayerToDB(player);
        this.showCombatUI();
        await TurnEngine.performAction('combat_round');
    },

    async handleParley() {
        const combat = this.activeCombat;
        const player = combat.player;
        const enemy = combat.enemy;
        const playerPersuasion = player.getSkillRank('wajutsu') + Math.floor(player.reputation.general / 5);
        const enemyResolve = enemy.combatSkill * 2 + (1 - enemy.fear) * 10;

        if (playerPersuasion > enemyResolve || Math.random() < 0.3) {
            combat.log.push(`You raise a hand, speaking words of reason. ${enemy.name} hesitates, then lowers their weapon.`);
            await this.endCombat('parley_success');
        } else {
            combat.log.push(`${enemy.name} scoffs at your words and presses the attack!`);
            combat.playerMorale -= 10;
            const enemyDamage = 5 + Math.floor(Math.random() * 10);
            player.health = Math.max(0, player.health - enemyDamage);
            combat.log.push(`They strike while you're speaking! (-${enemyDamage} health)`);
            if (player.health <= 0) {
                await this.endCombat('player_dead');
                return;
            }
            await saveNPC(enemy);
            await savePlayerToDB(player);
            this.showCombatUI();
        }
    },

    async enemyOffersYield() {
        const combat = this.activeCombat;
        const enemy = combat.enemy;
        const yieldNarration = GME.generateNarration('combat_yield', {
            enemy: enemy.name,
            ground: 'bloodstained earth'
        });
        combat.log.push(yieldNarration);

        const offer = generateYieldOffer(enemy);
        if (offer) {
            combat.log.push(`${enemy.name} offers: ${offer}.`);
            combat.pendingYieldOffer = offer;
            combat.status = 'yield_offered';
        }

        await saveNPC(enemy);
        this.showCombatUI();
        const acceptBtn = document.getElementById('btn-accept-yield');
        if (acceptBtn) acceptBtn.style.display = 'inline-block';
    },

    async acceptYield() {
        const combat = this.activeCombat;
        if (!combat || combat.status !== 'yield_offered') return;
        const player = combat.player;
        const enemy = combat.enemy;

        if (combat.pendingYieldOffer) {
            applyYieldOffer(player, enemy, combat.pendingYieldOffer);
            combat.log.push(`You accept ${enemy.name}'s surrender.`);
        }
        await this.endCombat('yield_accepted');
    },

    async enemyFlees() {
        const combat = this.activeCombat;
        const fleeNarration = GME.generateNarration('combat_flee', {
            enemy: combat.enemy.name,
            wilderness: 'the distance',
            ground: combat.location.terrainTags?.[0] || 'ground'
        });
        combat.log.push(fleeNarration);
        await this.endCombat('enemy_fled');
    },

    async attemptFlee() {
        const combat = this.activeCombat;
        if (!combat) return;
        const player = combat.player;
        const enemy = combat.enemy;
        const speedDiff = player.getSpeedModifier() - 0.7;
        const fleeChance = 0.3 + speedDiff + (player.fatigue < 50 ? 0.2 : -0.1);

        if (Math.random() < fleeChance) {
            combat.log.push('You break away and flee!');
            player.fatigue += 20;
            player.adjustHealth(-5);
            await this.endCombat('player_fled');
        } else {
            combat.log.push('You try to flee but are cut off!');
            const enemyDamage = 8 + Math.floor(Math.random() * 10);
            player.health = Math.max(0, player.health - enemyDamage);
            combat.log.push(`${enemy.name} strikes as you turn! (-${enemyDamage} health)`);
            combat.playerMorale -= 15;
            if (player.health <= 0) {
                await this.endCombat('player_dead');
                return;
            }
            await saveNPC(enemy);
            await savePlayerToDB(player);
            this.showCombatUI();
        }
    },

    async endCombat(result) {
        const combat = this.activeCombat;
        if (!combat) return;
        combat.status = result;

        const player = combat.player;
        const enemy = combat.enemy;

        switch (result) {
            case 'enemy_dead': {
                enemy.alive = false;
                const killNarration = GME.generateNarration('combat_kill', {
                    enemy: enemy.name,
                    enemyClass: enemy.category,
                    ground: 'bloodstained earth',
                    clan: enemy.faction || 'unknown'
                });
                combat.log.push(killNarration);
                if (enemy.wealth > 0) {
                    const lootAmount = enemy.wealth;
                    player.wealth += lootAmount;
                    enemy.wealth = 0;
                    combat.log.push(`You take ${lootAmount} mon from the body.`);
                }
                for (const inv of enemy.inventory) {
                    player.addItem(inv.itemId, inv.quantity);
                    combat.log.push(`You find: ${inv.itemId} x${inv.quantity}.`);
                }
                enemy.inventory = [];
                player.reputation.general += 1;
                break;
            }
            case 'player_dead': {
                player.die('combat wounds');
                combat.log.push('You fall. The world fades...');
                break;
            }
            case 'yield_accepted':
            case 'parley_success': {
                if (combat.pendingYieldOffer) {
                    applyYieldOffer(player, enemy, combat.pendingYieldOffer);
                }
                enemy.adjustRelationship(player.id, -10);
                combat.log.push('The battle ends with words rather than death.');
                player.reputation.general += 0.5;
                break;
            }
            case 'enemy_fled': {
                combat.log.push(`${enemy.name} has escaped. They may return another day.`);
                enemy.adjustRelationship(player.id, -20);
                player.reputation.general += 0.5;
                break;
            }
            case 'player_fled': {
                combat.log.push('You live to fight another day.');
                player.reputation.general -= 0.5;
                break;
            }
            case 'stalemate': {
                combat.log.push('Exhausted, both parties withdraw. The battle is a draw.');
                player.fatigue = Math.min(100, player.fatigue + 25);
                enemy.fatigue = 100;
                break;
            }
        }

        for (const line of combat.log) {
            GameState.log(line);
        }
        document.getElementById('log-panel').scrollTop = document.getElementById('log-panel').scrollHeight;

        if (player.health < 50) {
            const injury = player.health < 20 ? 'severe wounds' : 'moderate wounds';
            if (!player.injuries) player.injuries = [];
            player.injuries.push({ type: injury, severity: 100 - player.health, date: WorldClock.getCurrentContext().year * 360 + WorldClock.getCurrentContext().day });
        }

        await saveNPC(enemy);
        await savePlayerToDB(player);
        await TurnEngine.performAction('combat_round');

        this.activeCombat = null;
        showGameScreen();
    }
};

