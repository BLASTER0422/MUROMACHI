// Market buy/sell updates – use dbPut for economy changes
// (buyGood and sellGood already use a transaction, but we can streamline them to use dbGet/dbPut)
// We'll override them with safe versions:

const origBuyGood = buyGood;
buyGood = async function(goodKey, quantity) {
    const player = GameState.player;
    const locId = GameState.currentLocation?.locationId;
    const price = await EconomyEngine.getPrice(locId, goodKey);
    const total = price * quantity;
    if (player.wealth < total) { alert('Not enough mon.'); return; }
    const supply = await EconomyEngine.getSupply(locId, goodKey);
    if (supply < quantity) { alert('Not enough stock.'); return; }
    const goodDef = MARKET_GOODS[goodKey];
    const addedWeight = (goodDef?.weight || 1) * quantity;
    if (player.getCurrentWeight() + addedWeight > player.getMaxCarry()) { alert('Overburdened.'); return; }
    player.wealth -= total;
    const itemId = 'item_' + goodKey;
    player.addItem(itemId, quantity);
    // Update economy
    const econData = await dbGet(STORES.economy, locId);
    if (econData?.goods?.[goodKey]) {
        econData.goods[goodKey].supply = Math.max(0, econData.goods[goodKey].supply - quantity);
        await dbPut(STORES.economy, econData);
    }
    delete EconomyEngine.priceCache[`${locId}_${goodKey}`];
    GameState.log(`Bought ${quantity}x ${goodDef.name} for ${total} mon.`);
    await savePlayerToDB(player);
    actionVisitMarket();
};

const origSellGood = sellGood;
sellGood = async function(goodKey, quantity) {
    const player = GameState.player;
    const locId = GameState.currentLocation?.locationId;
    const itemId = 'item_' + goodKey;
    if (!player.hasItem(itemId, quantity)) { alert('You don\'t have that many.'); return; }
    const price = await EconomyEngine.getPrice(locId, goodKey);
    const sellPrice = Math.floor(price * 0.7);
    const totalEarnings = sellPrice * quantity;
    player.removeItem(itemId, quantity);
    player.wealth += totalEarnings;
    const econData = await dbGet(STORES.economy, locId);
    if (econData?.goods?.[goodKey]) {
        econData.goods[goodKey].supply += quantity;
        await dbPut(STORES.economy, econData);
    }
    delete EconomyEngine.priceCache[`${locId}_${goodKey}`];
    GameState.log(`Sold ${quantity}x ${MARKET_GOODS[goodKey].name} for ${totalEarnings} mon.`);
    await savePlayerToDB(player);
    actionVisitMarket();
};

// ========== FINAL BOOTSTRAP (Replaces all early IIFEs) ==========
(async function startGame() {
    try {
        // 1. Open DB and seed world
        db = await openDB();
        await bootstrapWorld(db);

        // 2. Seed locations & economy
        await seedAllLocations();
        await initializeAllEconomies();

        // 3. Start the world clock
        await WorldClock.loadClock();
        WorldClock.updateStatusBar();

        // 4. Restore active events
        await loadRecentEvents();

        // 5. Try to load existing player save
        const sessionPtr = localStorage.getItem('sessionPointer');
        if (sessionPtr) {
            try {
                const ptr = JSON.parse(sessionPtr);
                if (ptr.currentPlayerId) {
                    const player = await loadPlayerFromDB();
                    if (player) {
                        GameState.setPlayer(player);
                        GameState.currentLocation = await loadLocation(player.locationId);
                        document.getElementById('location-display').textContent = GameState.currentLocation?.name || 'Unknown';
                        showGameScreen();
                        console.log('Game loaded successfully.');
                        return;
                    }
                }
            } catch (e) {
                console.warn('Save file corrupted, starting new game.');
            }
        }

        // 6. No valid save – show title screen
        showTitleScreen();
        console.log('Title screen ready.');
    } catch (e) {
        console.error('Initialization failed:', e);
        document.getElementById('main-content').innerHTML = `<h2>Error</h2><p>${e.message}</p>`;
    }
})();

