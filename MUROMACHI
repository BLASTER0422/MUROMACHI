        npc.employerId = null;
        npc.hireMode = null;
        npc.wage = 0;
        npc.adjustRelationship(player.id, -20);
    }
    player.followers = player.followers.filter(id => id !== npcId);
    await saveNPC(npc);
    await savePlayerToDB(player);
    GameState.log(`${npc.name} is no longer in your service.`);
