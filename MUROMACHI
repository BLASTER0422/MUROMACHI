// ---------- AGING & BIRTHDAY SYSTEM ----------
async function checkAgingAndBirthdays() {
    const clock = WorldClock.currentClock;
    if (!clock) return;

    if (GameState.player && GameState.player.isAlive) {
        const player = GameState.player;
        const birthMonth = player.birthMonth || 1;
        const birthDay = player.birthDay || 1;
        if (clock.month === birthMonth && clock.day === birthDay) {
            player.age = clock.year - player.birthYear;
            GameState.log(`Today is your birthday. You turn ${player.age}.`);
            applyAgeEffects(player);
        }
    }
}

function applyAgeEffects(player) {
    const age = player.age;
    if (age >= 55) {
        const physicalSkills = ['kenjutsu','kyujutsu','sojutsu','naginatajutsu','bojutsu','jujutsu','tantojutsu','bajutsu','suijutsu','hojutsu'];
        for (const skill of physicalSkills) {
            if (player.skills[skill] > 1) {
                player.skills[skill] = Math.max(1, player.skills[skill] - 1);
            }
        }
        GameState.log('Age has slowed your sword arm...');
    }
    if (age >= 70) {
        player.adjustHealth(-10);
        GameState.log('The weight of years presses heavily upon you.');
    }
    if (age >= 80) {
        player.die('old age');
        GameState.log('You have lived a full life. The ancestors call you home.');
    }
}

// ---------- MARRIAGE SYSTEM ----------
async function proposeMarriage(npcId) {
    const player = GameState.player;
    if (!player) return;
    const npc = await loadNPC(npcId);
    if (!npc || !npc.alive) return;
    if (player.spouseId) { alert('You are already married.'); return; }
    if (npc.spouseId) { alert(`${npc.name} is already married.`); return; }

    const relationship = npc.getRelationship(player.id);
    if (relationship < 50) {
        alert(`${npc.name} does not feel close enough to you for marriage.`);
        return;
    }
    if (npc.category === 'samurai' && player.reputation.general < 20) {
        alert(`${npc.name}'s family would not approve of your status.`);
        return;
    }

    const dowry = npc.profession === 'noble' ? 100 : (npc.category === 'samurai' ? 50 : 20);
    if (player.wealth < dowry) {
        alert(`You need at least ${dowry} mon for a dowry.`);
        return;
    }

    const confirm = window.confirm(`Propose marriage to ${npc.name}? This will cost ${dowry} mon as dowry.`);
    if (!confirm) return;

    player.wealth -= dowry;
    npc.wealth += dowry;
    player.spouseId = npc.npcId;
    npc.spouseId = player.id;
    npc.adjustRelationship(player.id, 30);
    GameState.log(`You and ${npc.name} are now wed. The ceremony is simple but blessed.`);

    await saveNPC(npc);
    await savePlayerToDB(player);
    showGameScreen();
}

