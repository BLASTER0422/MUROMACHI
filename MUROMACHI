async function finalizeCharacter() {
    const name = document.getElementById('char-name').value.trim() || 'Traveler';
    const age = parseInt(document.getElementById('char-age').value) || 20;
    const gender = document.getElementById('char-gender').value;
    const origin = document.getElementById('char-origin').value;

    const checked = document.querySelectorAll('#skill-categories input:checked');
    const skillKeys = Array.from(checked).map(cb => cb.value);
    if (skillKeys.length === 0) {
        alert('Please select at least one skill.');
        return;
    }

    const skills = {};
    ALL_SKILLS.forEach(s => { skills[s.key] = 0; });
    skillKeys.forEach(key => { skills[key] = 2; });

    let inventory = [];
    let wealth = 50;
    let locationId = 'shimosa_kogane';
    switch (origin) {
        case 'farmer':
            inventory = [{ itemId: 'item_hoe', quantity: 1 }, { itemId: 'item_rice_bag', quantity: 2 }];
            wealth = 30;
            break;
        case 'merchant':
            inventory = [{ itemId: 'item_silk_bolt', quantity: 1 }, { itemId: 'item_dried_fish', quantity: 3 }];
            wealth = 120;
            break;
        case 'ronin':
            inventory = [{ itemId: 'item_katana', quantity: 1 }, { itemId: 'item_dried_fish', quantity: 1 }];
            wealth = 15;
            locationId = 'musashi_edo';
            break;
        case 'shrine':
            inventory = [{ itemId: 'item_medicine_herb', quantity: 3 }, { itemId: 'item_rice_bag', quantity: 1 }];
            wealth = 25;
            break;
        case 'wanderer':
        default:
            inventory = [{ itemId: 'item_millet_bag', quantity: 2 }];
            wealth = 40;
            break;
    }

    const player = new PlayerCharacter({
        name, age, gender, origin,
        skills, wealth, inventory, locationId,
        birthMonth: WorldClock.currentClock?.month || 1
    });

    if (skills['kenjutsu'] >= 1 && inventory.some(i => i.itemId === 'item_katana')) {
        player.equipped.weapon = 'item_katana';
    }

    await savePlayerToDB(player);
    GameState.setPlayer(player);
    GameState.currentLocation = await loadLocation(locationId);

    document.getElementById('location-display').textContent = GameState.currentLocation?.name || 'Unknown';
    WorldClock.updateStatusBar();
    document.getElementById('log-panel').innerHTML = '';

    const narration = GME.generateNarration('travel_arrive', {
        player: { name: player.name },
        destination: GameState.currentLocation?.name || 'these lands',
        timeOfDay: WorldClock.getCurrentContext().timeOfDay,
        season: WorldClock.getCurrentContext().season,
        impression: 'The world opens before you, full of peril and promise.'
    });
    GameState.log(narration);
    showGameScreen();
}

// ---------- SAVE / LOAD PLAYER FROM INDEXEDDB ----------
async function savePlayerToDB(player) {
    if (!db) return;
    const tx = db.transaction(STORES.playerState, 'readwrite');
    const store = tx.objectStore(STORES.playerState);
    store.put({ id: 'player', data: player.toJSON() });
    await new Promise(res => { tx.oncomplete = res; });
    localStorage.setItem('sessionPointer', JSON.stringify({ currentPlayerId: player.id, lastSaveTimestamp: Date.now() }));
}

async function loadPlayerFromDB() {
    if (!db) return null;
    const tx = db.transaction(STORES.playerState, 'readonly');
    const store = tx.objectStore(STORES.playerState);
    const record = await new Promise(res => { const req = store.get('player'); req.onsuccess = () => res(req.result); });
    if (record && record.data) return PlayerCharacter.fromJSON(record.data);
    return null;
}

async function loadLocation(locationId) {
    if (!db) return { locationId: 'unknown', name: 'Unknown', type: 'village', province: 'shimosa', terrainTags: [] };
    const tx = db.transaction(STORES.locations, 'readonly');
    const store = tx.objectStore(STORES.locations);
    const loc = await new Promise(res => { const req = store.get(locationId); req.onsuccess = () => res(req.result); });
    return loc || { locationId: 'unknown', name: 'Unknown', type: 'village', province: 'shimosa', terrainTags: [] };
}

// ---------- LOAD / DELETE SCREENS ----------
async function showLoadScreen() {
    const main = document.getElementById('main-content');
    const player = await loadPlayerFromDB();
    if (!player) {
        main.innerHTML = '<h2>No Saved Game</h2><p>No previous journey was found. Start a new game.</p>';
        document.getElementById('action-panel').innerHTML = '<button onclick="showTitleScreen()">← Back</button>';
        return;
    }
    const clock = WorldClock.currentClock || { year: 1380, month: 1, day: 1 };
    const monthName = WorldClock.monthNames[clock.month - 1] || 'Unknown';
    const loc = await loadLocation(player.locationId);
    main.innerHTML = `
        <h2>📜 Saved Journey</h2>
        <div class="panel">
            <p><strong>Name:</strong> ${player.name}</p>
            <p><strong>Age:</strong> ${player.age} | <strong>Origin:</strong> ${player.origin}</p>
            <p><strong>Location:</strong> ${loc.name || 'Unknown'}</p>
            <p><strong>Date:</strong> Year ${clock.year}, ${monthName} ${clock.day}${WorldClock.ordinal(clock.day)}</p>
            <p><strong>Wealth:</strong> ${player.wealth} mon</p>
            <p><strong>Health:</strong> ${player.health}/100 | <strong>Hunger:</strong> ${Math.round(player.hunger)} | <strong>Thirst:</strong> ${Math.round(player.thirst)}</p>
