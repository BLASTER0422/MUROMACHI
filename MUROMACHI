        const canLearn = skillRank >= recipe.minRank;
        const hasMats = checkMaterials(player, recipe.materials);
        const buttonDisabled = !canLearn || !hasMats ? 'disabled' : '';
        const missing = !canLearn ? ` (need ${recipe.skill} rank ${recipe.minRank})` : (!hasMats ? ' (missing materials)' : '');
        craftHTML += `
            <div style="border-bottom:1px solid var(--border); padding:6px 0;">
                <strong>${recipe.name}</strong> <small>${recipe.description}</small><br>
                Skill: ${recipe.skill} (yours: ${skillRank}) | Time: ${recipe.time} min<br>
                Materials: ${formatMaterialList(recipe.materials)}<br>
                <button onclick="craftItem('${recipeId}')" ${buttonDisabled}>Craft</button>${missing}
            </div>
        `;
    }
    craftHTML += '</div>';
    main.innerHTML += craftHTML;
    document.getElementById('action-panel').innerHTML = '<button onclick="showGameScreen()">← Back</button>';
}

function checkMaterials(player, materials) {
    for (const [itemId, qty] of Object.entries(materials)) {
        if (!player.hasItem(itemId, qty)) return false;
    }
    return true;
}

function formatMaterialList(materials) {
    return Object.entries(materials).map(([id, qty]) => `${id} x${qty}`).join(', ');
}

async function craftItem(recipeId) {
    const player = GameState.player;
    if (!player) return;
    const recipe = CRAFTING_RECIPES[recipeId];
    if (!recipe) return;

    if (!player.canUseSkill(recipe.skill, recipe.minRank)) {
        alert(`You lack the ${recipe.skill} skill (need rank ${recipe.minRank}).`);
        return;
    }
    if (!checkMaterials(player, recipe.materials)) {
        alert('Missing materials.');
        return;
    }

    for (const [itemId, qty] of Object.entries(recipe.materials)) {
        player.removeItem(itemId, qty);
    }

    const skillRank = player.getSkillRank(recipe.skill);
    const successThreshold = 30 + skillRank * 6;
    const roll = Math.random() * 100;
    const success = roll < successThreshold;

    await TurnEngine.performAction('craft_medium', { timeOverride: recipe.time });

    if (success) {
        player.addItem(recipe.product.itemId, recipe.product.quantity);
        GameState.log(`You successfully craft ${recipe.name}!`);
    } else {
        GameState.log(`Your attempt to craft ${recipe.name} fails. Materials are wasted.`);
    }

    await savePlayerToDB(player);
    actionCrafting();
}

