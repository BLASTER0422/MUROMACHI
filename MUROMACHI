// ---------- TURN ENGINE ----------
const TurnEngine = {
    actionQueue: [],
    isProcessing: false,
    autoSleepTriggered: false,

    timeCosts: {
        walk_settlement: 15,
        browse_market: 20,
        dialogue: 10,
        forage: 60,
        hunt: 90,
        fish: 75,
        craft_small: 60,
        craft_medium: 180,
        craft_large: 480,
        combat_round: 1,
        travel_1_ri: 90,
        sleep: 420,
        rest_short: 30,
        chore: 45
    },

    async performAction(actionType, actionData = {}) {
        if (this.isProcessing) return;
        this.isProcessing = true;
        this.autoSleepTriggered = false;
        try {
            const player = GameState.player;
            const currentLoc = GameState.currentLocation;
            const weather = GameState.currentWeather || 'clear';
            let timeCost = this.timeCosts[actionType] || 15;
            if (actionType === 'travel_1_ri' && player) {
                const speedMod = player.getSpeedModifier ? player.getSpeedModifier() : 1.0;
                timeCost = Math.round(timeCost / speedMod);
            }
            if (actionType === 'travel_1_ri' && actionData.terrain) {
                const terrainMods = { plains: 1.0, hills: 0.75, mountain: 0.5, forest: 0.7, river: 0.6, coast: 0.85 };
                const mod = terrainMods[actionData.terrain] || 1.0;
                timeCost = Math.round(timeCost / mod);
            }
            if (['rain', 'snow', 'storm'].includes(weather) && actionType.startsWith('travel')) {
                timeCost = Math.round(timeCost * 1.3);
            }
            if (actionData.timeOverride) timeCost = actionData.timeOverride;
            await WorldClock.advanceTime(timeCost, currentLoc, weather);
            const hour = WorldClock.currentClock ? WorldClock.currentClock.hour : 6;
            if (hour === 23 && !this.autoSleepTriggered) {
                await this.triggerAutoSleep(player, currentLoc, weather);
            }
            if (player) {
                player.updateSurvival(timeCost, actionType);
            }
            return { success: true, timePassed: timeCost };
        } finally {
            this.isProcessing = false;
        }
    },

    async triggerAutoSleep(player, currentLoc, weather) {
        this.autoSleepTriggered = true;
        let sleepNarration = '';
        if (!player || !player.isAlive) return;
        if (currentLoc && (currentLoc.type === 'town' || currentLoc.type === 'city' || currentLoc.type === 'village')) {
            const innCost = currentLoc.type === 'city' ? 15 : (currentLoc.type === 'town' ? 10 : 5);
            if (player.wealth >= innCost) {
                player.wealth -= innCost;
                sleepNarration = `Night falls over ${currentLoc.name}. You find lodging at a local inn, paying ${innCost} mon for a bed. The innkeeper nods as you retire.`;
            } else {
                sleepNarration = `Without enough coin for the inn, you find a corner near the shrine to sleep. The night is ${weather === 'snow' ? 'bitterly cold' : 'uncomfortable'}.`;
                player.adjustHealth(-5);
            }
        } else if (player.activeShelter) {
            const campRoll = Math.random();
            if (campRoll > 0.3) {
                sleepNarration = `You retreat to your shelter. The fire keeps the ${weather} night at bay. Sleep comes, albeit lightly.`;
            } else {
                sleepNarration = `Your shelter struggles against the ${weather} weather. You sleep fitfully, waking often.`;
                player.adjustHealth(-3);
            }
        } else {
            const survivalSkill = player.skills['taikyu'] || 0;
            const survivalRoll = Math.random() * 100;
            if (survivalRoll < 20 + survivalSkill * 5) {
                sleepNarration = `You find a dry spot off the road. Wrapping yourself in what you have, you manage some rest under the open sky.`;
            } else if (weather === 'snow' || weather === 'storm') {
                sleepNarration = `The ${weather} makes sleeping nearly impossible. You huddle miserably, shivering until dawn.`;
                player.adjustHealth(-10);
                player.adjustFatigue(10);
            } else {
                sleepNarration = `You make do with the roadside. The ground is hard, and sleep is shallow, but you survive the night.`;
                player.adjustHealth(-2);
            }
        }
        if (currentLoc) {
            await WorldClock.advanceTime(420, currentLoc, weather);
            if (WorldClock.currentClock) WorldClock.currentClock.hour = 6;
            await WorldClock.saveClock();
        }
        GameState.log(sleepNarration);
        const logEl = document.getElementById('log-panel');
        if (logEl) {
            logEl.innerHTML += `\n\n=== ${sleepNarration} ===\n`;
            logEl.scrollTop = logEl.scrollHeight;
        }
    },

    scheduleAction(actionFn, label) {
        this.actionQueue.push({ fn: actionFn, label });
        if (!this.isProcessing) this.processQueue();
    },

    async processQueue() {
        while (this.actionQueue.length > 0) {
            const action = this.actionQueue.shift();
            try { await action.fn(); } catch (e) { console.error('Action failed:', action.label, e); }
        }
    }
};

