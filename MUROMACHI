// ---------- TRIAL SYSTEM ----------
async function handleTrial(player, guard, location) {
    GameState.log('You surrender to the guard and are brought before the magistrate.');
    const severity = Math.floor((player.bounty || 0) / 10);
    const magistrateMood = Math.random();
    let punishment = '';
    if (magistrateMood > 0.7 || severity > 8) {
        punishment = 'execution';
    } else if (severity > 4) {
        punishment = 'exile';
    } else if (severity > 2) {
        punishment = 'fine';
    } else {
        punishment = 'warning';
    }

    switch (punishment) {
        case 'execution':
            GameState.log('The magistrate orders your execution. Your journey ends here.');
            player.die('execution');
            break;
        case 'exile':
            GameState.log('You are banished from this province. Your possessions are confiscated.');
            player.wealth = 0;
            player.inventory = [];
            const exileLocation = findExileLocation(location.province);
            if (exileLocation) {
                player.locationId = exileLocation.locationId;
                GameState.currentLocation = exileLocation;
                GameState.log(`You are escorted to the border and released near ${exileLocation.name}.`);
            }
            player.bounty = Math.max(0, player.bounty - 20);
            break;
        case 'fine':
            const fine = Math.min(player.wealth, severity * 5);
            player.wealth -= fine;
            player.bounty = Math.max(0, player.bounty - severity * 5);
            GameState.log(`You pay a fine of ${fine} mon and are released.`);
            break;
        case 'warning':
            GameState.log('The magistrate gives you a stern warning and releases you.');
            player.bounty = 0;
            break;
    }
