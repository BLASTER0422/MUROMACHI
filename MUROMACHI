                    { text: "{npc} pales. \"Please... there's no need for violence. Take this.\" They offer {offering}.", weight: 3 },
                    { text: "\"You think you frighten me?\" {npc}'s hand moves toward their own weapon.", weight: 2 }
                ]
            },

            // ---- TOWN LIFE ----
            town: {
                market: [
                    { text: "The market square bustles with {crowdSize}. Merchants call out prices, and the scent of {scent} fills the air.", weight: 3 },
                    { text: "Stalls line the street, piled with goods from across the provinces.", weight: 2 }
                ],
                inn: [
                    { text: "The inn is {innAtmosphere}. A fire crackles in the hearth, and travelers exchange news.", weight: 3 }
                ],
                shrine: [
                    { text: "Incense drifts through the shrine gate. A priest chants softly within.", weight: 3 }
                ]
            },

            // ---- WEATHER & TIME ----
            weather: {
                rain: "Rain falls steadily, turning the {ground} to mud.",
                snow: "Snowflakes drift down, muffling the world in white.",
                heat: "The sun beats down mercilessly. The air shimmers with heat.",
                cold: "Your breath mists in the frigid air. Winter's grip is tight.",
                clear: "The sky is clear, a vast expanse of {skyColor} overhead.",
                wind: "A strong wind blows, rustling leaves and carrying distant sounds."
            },
            timeOfDay: {
                dawn: "The first light of dawn creeps over the horizon.",
                morning: "Morning sunlight bathes the land in gold.",
                noon: "The sun stands high, shadows short and sharp.",
                afternoon: "The afternoon wears on, shadows lengthening.",
                dusk: "Dusk paints the sky in shades of orange and purple.",
                night: "Darkness has fallen. Stars prick the velvet sky.",
                lateNight: "The world is still. Even the insects hold their breath."
            },
            seasonalDetail: {
                spring: "Cherry blossoms drift on the breeze. New life stirs in the fields.",
                summer: "Cicadas drone in the heat. The rice paddies shimmer green.",
                autumn: "Red maple leaves carpet the path. The harvest moon hangs heavy.",
                winter: "Bare branches claw at a grey sky. Smoke rises from village hearths."
            }
        };
    }

    // ---------- MARKOV CHAIN TRANSITIONS ----------
    buildMarkovChains() {
        return {
            combatFlow: {
                opening: ['hit', 'miss', 'enemyHit', 'enemyMiss'],
                hit: ['hit', 'enemyMiss', 'kill', 'yield', 'miss'],
                miss: ['enemyHit', 'hit', 'miss', 'enemyMiss'],
                enemyHit: ['hit', 'miss', 'enemyMiss', 'defensiveAction'],
                enemyMiss: ['hit', 'miss', 'kill'],
                kill: ['lastWords'],
                yield: ['resolution'],
                flee: ['resolution']
            },
            travelFlow: {
                start: ['progress', 'progress', 'encounter'],
                progress: ['progress', 'encounter', 'arrive', 'rest'],
                rest: ['progress', 'arrive', 'encounter']
            },
            socialFlow: {
                greeting: ['giftAccept', 'giftReject', 'choreDone', 'insultReact', 'threatenReact'],
                threatenReact: ['yieldOffer', 'combatStart']
            }
        };
    }

    // ---------- CONTEXT EXTRACTION ----------
    extractContext(actionData) {
        const ctx = {
            player: actionData.player || {},
            npc: actionData.npc || {},
            enemy: actionData.enemy || {},
            location: actionData.location || {},
            weapon: actionData.weapon || 'bare hands',
            enemyWeapon: actionData.enemyWeapon || 'blade',
            terrain: actionData.terrain || 'earth',
            ground: actionData.ground || 'ground',
            season: actionData.season || 'spring',
            weather: actionData.weather || 'clear',
            timeOfDay: actionData.timeOfDay || 'morning',
            sky: actionData.sky || 'bright',
            skyColor: actionData.skyColor || 'blue',
            road: actionData.road || 'dirt path',
            origin: actionData.origin || 'your last stop',
            destination: actionData.destination || 'your destination',
            distance: actionData.distance || 'several',
            landmark: actionData.landmark || 'ancient pine',
            scenery: actionData.scenery || 'familiar countryside',
            crowdSize: actionData.crowdSize || 'a modest crowd',
            scent: actionData.scent || 'grilled fish',
            innAtmosphere: actionData.innAtmosphere || 'warm and welcoming',
