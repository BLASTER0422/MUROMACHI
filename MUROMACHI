class WorldClockManager {
    constructor() {
        this.monthNames = [
            'Mutsuki', 'Kisaragi', 'Yayoi', 'Uzuki', 'Satsuki', 'Minazuki',
            'Fumizuki', 'Hazuki', 'Nagatsuki', 'Kannazuki', 'Shimotsuki', 'Shiwasu'
        ];
        this.zodiacHours = [
            { name: 'Rat', start: 23, end: 1 },
            { name: 'Ox', start: 1, end: 3 },
            { name: 'Tiger', start: 3, end: 5 },
            { name: 'Hare', start: 5, end: 7 },
            { name: 'Dragon', start: 7, end: 9 },
            { name: 'Serpent', start: 9, end: 11 },
            { name: 'Horse', start: 11, end: 13 },
            { name: 'Goat', start: 13, end: 15 },
            { name: 'Monkey', start: 15, end: 17 },
            { name: 'Rooster', start: 17, end: 19 },
            { name: 'Dog', start: 19, end: 21 },
            { name: 'Boar', start: 21, end: 23 }
        ];
        this.seasons = {
            spring: [1, 2, 3],
            summer: [4, 5, 6],
            autumn: [7, 8, 9],
            winter: [10, 11, 12]
        };
        this.currentClock = null;
    }

    async loadClock() {
        if (!db) { console.warn('DB not ready for clock load'); return; }
        const tx = db.transaction(STORES.worldClock, 'readonly');
        const store = tx.objectStore(STORES.worldClock);
        this.currentClock = await new Promise((res, rej) => {
            const req = store.get('clock');
            req.onsuccess = () => res(req.result);
            req.onerror = () => rej(req.error);
        });
        if (!this.currentClock) {
            this.currentClock = {
                id: 'clock', year: 1380, month: 1, day: 1, hour: 5,
                season: 'spring', temperature: 8, era: 'Kōryaku 2 / Tenju 6'
            };
        }
    }

    async saveClock() {
        if (!db) return;
        const tx = db.transaction(STORES.worldClock, 'readwrite');
        const store = tx.objectStore(STORES.worldClock);
        store.put(this.currentClock);
        await new Promise(res => { tx.oncomplete = res; });
    }

    getSeason(month) {
        for (const [season, months] of Object.entries(this.seasons)) {
            if (months.includes(month)) return season;
        }
        return 'spring';
    }

    getZodiacHour(hour) {
        for (const zh of this.zodiacHours) {
            if (zh.start <= zh.end) {
                if (hour >= zh.start && hour < zh.end) return zh.name;
            } else {
                if (hour >= zh.start || hour < zh.end) return zh.name;
            }
        }
        return 'Rat';
    }

    getTimeOfDay(hour) {
        if (hour >= 5 && hour < 8) return 'dawn';
        if (hour >= 8 && hour < 11) return 'morning';
        if (hour >= 11 && hour < 13) return 'noon';
        if (hour >= 13 && hour < 17) return 'afternoon';
        if (hour >= 17 && hour < 19) return 'dusk';
        if (hour >= 19 && hour < 23) return 'night';
        return 'lateNight';
    }

    calculateTemperature(provinceId, month, hour, weather) {
        const provinceBase = {
            shimosa: { winter: 3, spring: 12, summer: 26, autumn: 16 },
            hitachi: { winter: 0, spring: 10, summer: 24, autumn: 14 },
            shimotsuke: { winter: -2, spring: 10, summer: 24, autumn: 13 },
            kozuke: { winter: -1, spring: 11, summer: 25, autumn: 14 },
            musashi: { winter: 2, spring: 12, summer: 26, autumn: 16 },
            kazusa: { winter: 4, spring: 13, summer: 27, autumn: 17 },
            awa: { winter: 5, spring: 14, summer: 28, autumn: 18 },
            sagami: { winter: 3, spring: 13, summer: 27, autumn: 17 }
        };
        const season = this.getSeason(month);
        const base = (provinceBase[provinceId] || provinceBase.shimosa)[season];
        let timeMod = 0;
        if (hour >= 1 && hour <= 4) timeMod = -4;
        else if (hour >= 5 && hour <= 7) timeMod = -2;
        else if (hour >= 8 && hour <= 10) timeMod = 1;
        else if (hour >= 11 && hour <= 14) timeMod = 4;
        else if (hour >= 15 && hour <= 17) timeMod = 2;
        else if (hour >= 18 && hour <= 20) timeMod = -1;
        else timeMod = -3;
        const weatherMod = { clear: 0, rain: -3, snow: -8, storm: -5, fog: -1, windy: -2, cloudy: 0 };
        const wMod = weatherMod[weather] || 0;
        return Math.round(base + timeMod + wMod);
    }

    async advanceTime(minutes, playerLocation, weather = 'clear') {
        if (!this.currentClock) await this.loadClock();
        let totalMinutes = (this.currentClock.hour * 60) + (this.currentClock.day * 24 * 60) + (this.currentClock.month * 30 * 24 * 60);
        totalMinutes += minutes;
        const minutesInDay = 24 * 60;
        const daysPerMonth = 30;
        const monthsPerYear = 12;
        let totalDays = Math.floor(totalMinutes / minutesInDay);
        const remainingMinutes = totalMinutes % minutesInDay;
        this.currentClock.hour = Math.floor(remainingMinutes / 60);
        this.currentClock.day = (totalDays % daysPerMonth) + 1;
        let carryMonths = Math.floor(totalDays / daysPerMonth);
        this.currentClock.month = (carryMonths % monthsPerYear) + 1;
        let carryYears = Math.floor(carryMonths / monthsPerYear);
        this.currentClock.year += carryYears;
        this.currentClock.season = this.getSeason(this.currentClock.month);
        const provId = (playerLocation && playerLocation.province) ? playerLocation.province : 'shimosa';
        this.currentClock.temperature = this.calculateTemperature(provId, this.currentClock.month, this.currentClock.hour, weather);
        await this.saveClock();
        this.updateStatusBar();
    }

    getDisplayTime() {
        const c = this.currentClock;
        if (!c) return 'Time unknown';
        const zodiac = this.getZodiacHour(c.hour);
        const monthName = this.monthNames[c.month - 1] || 'Unknown';
        return `Year ${c.year}, ${monthName} ${c.day}${this.ordinal(c.day)}, Hour of the ${zodiac}`;
    }

    ordinal(n) {
        if (n === 1) return 'st';
        if (n === 2) return 'nd';
        if (n === 3) return 'rd';
        return 'th';
    }

    getCurrentContext() {
        if (!this.currentClock) return { year: 1380, month: 1, day: 1, hour: 5, season: 'spring', temperature: 8, timeOfDay: 'dawn', zodiacHour: 'Hare' };
        return {
            year: this.currentClock.year,
            month: this.currentClock.month,
            day: this.currentClock.day,
            hour: this.currentClock.hour,
            season: this.currentClock.season,
            temperature: this.currentClock.temperature,
            timeOfDay: this.getTimeOfDay(this.currentClock.hour),
            zodiacHour: this.getZodiacHour(this.currentClock.hour)
        };
    }

    updateStatusBar() {
        const timeEl = document.getElementById('time-display');
        const tempEl = document.getElementById('health-display');
        if (timeEl) timeEl.textContent = this.getDisplayTime();
        if (tempEl && this.currentClock) tempEl.textContent = `${this.currentClock.temperature}°C | ${this.currentClock.season}`;
    }
}

