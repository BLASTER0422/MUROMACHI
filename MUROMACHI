                    { text: "A tug on the line! You pull a gleaming {fish} from the water.", weight: 3 },
                    { text: "The river gives up its bounty — a fine {fish} flops on the bank.", weight: 2 }
                ],
                campSuccess: [
                    { text: "You build a sturdy camp. The fire crackles, keeping the darkness at bay.", weight: 3 },
                    { text: "Your shelter stands firm against the night breeze. A safe haven in the wild.", weight: 2 }
                ],
                campFail: [
                    { text: "The wind snuffs your fire. You huddle in the dark, cold and exposed.", weight: 2 }
                ]
            },

            // ---- SOCIAL ----
            social: {
                greeting: [
                    { text: "\"Ah, a traveler. What brings you to {location}?\" {npc} regards you with {expression}.", weight: 3 },
                    { text: "{npc} looks up from their work. \"Haven't seen your face before. You're new here.\"", weight: 2 }
                ],
                giftAccept: [
                    { text: "{npc}'s eyes widen. \"This is... for me? You have my gratitude.\"", weight: 3 },
                    { text: "\"You're too kind.\" {npc} accepts your gift with a bow.", weight: 2 }
                ],
                giftReject: [
                    { text: "{npc} shakes their head. \"I cannot accept this. But thank you.\"", weight: 2 }
                ],
                choreDone: [
                    { text: "\"You've helped more than you know.\" {npc} smiles, the task complete.", weight: 3 }
                ],
                insultReact: [
