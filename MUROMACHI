                        { text: "You test the space between you with a probing strike, measuring {enemy}'s reflexes.", weight: 3 },
                        { text: "A careful step forward, then back — you study {enemy} as a hawk studies a serpent.", weight: 2 }
                    ]
                },
                hit: [
                    { text: "Your {weapon} finds flesh. {enemy} staggers, a cry escaping their lips.", weight: 4 },
                    { text: "A clean strike! {enemy} reels, blood spotting the {ground}.", weight: 3 },
                    { text: "You land a vicious blow. {enemy}'s guard falters.", weight: 3 }
                ],
                miss: [
                    { text: "{enemy} parries at the last instant, steel ringing against steel.", weight: 3 },
                    { text: "Your strike goes wide. {enemy} sidesteps, breathing hard.", weight: 3 },
                    { text: "The blow fails to connect. {enemy} counters with a snarl.", weight: 2 }
                ],
                enemyHit: [
                    { text: "{enemy}'s {enemyWeapon} catches you. Pain flares across your body.", weight: 3 },
                    { text: "You fail to block in time. The strike lands hard.", weight: 3 }
                ],
                enemyMiss: [
                    { text: "You deflect {enemy}'s attack, the force reverberating up your arm.", weight: 3 },
                    { text: "{enemy} overreaches. You slip aside, unharmed.", weight: 2 }
                ],
                kill: [
                    { text: "Your final blow lands true. {enemy} crumples to the {ground}, life fading.", weight: 3 },
                    { text: "With a decisive strike, you end it. {enemy} falls, never to rise again.", weight: 3 }
                ],
                yield: [
                    { text: "\"Wait! I yield!\" {enemy} drops their weapon, hands raised, breath ragged.", weight: 3 },
                    { text: "\"Enough! Spare me, and I'll make it worth your while.\" {enemy} sinks to their knees.", weight: 2 }
                ],
                flee: [
                    { text: "Panic overtakes {enemy}. They turn and flee into the {wilderness}.", weight: 3 },
                    { text: "{enemy} breaks away, scrambling over the {ground} in desperate retreat.", weight: 2 }
                ],
                lastWords: {
                    bandit: [
                        "\"Curse you... should've stayed... in the hills...\"",
                        "\"All this... for a few copper...\"",
                        "\"My brother... will find you...\""
                    ],
                    samurai: [
                        "\"A worthy... end... my ancestors... welcome me...\"",
                        "\"My lord... I have failed... the {clan} name...\"",
                        "\"Remember me... when you face... the next blade...\""
                    ],
                    scout: [
                        "\"You... don't know... what's coming...\"",
                        "\"Three days... the army... behind me...\"",
                        "\"They'll... burn everything...\""
                    ],
                    merchant: [
                        "\"My wealth... take it... just... let my family know...\"",
                        "\"All my trading... ends here... in the dirt...\""
                    ],
                    commoner: [
                        "\"Please... my children...\"",
                        "\"I never wanted... any of this...\""
                    ]
                }
            },

            // ---- TRAVEL ----
            travel: {
                start: [
                    { text: "You set out from {origin}, the road stretching ahead beneath a {sky} sky.", weight: 3 },
                    { text: "With your belongings secured, you leave {origin} behind and step onto the {road}.", weight: 3 }
                ],
                progress: [
                    { text: "The {road} winds through {scenery}. {seasonalDetail}", weight: 3 },
                    { text: "You pass a {landmark}, the sounds of {origin} fading with each step.", weight: 2 }
                ],
                arrive: [
                    { text: "After {distance} ri of travel, {destination} comes into view. {impression}", weight: 3 },
