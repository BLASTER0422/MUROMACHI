// ---------- FRIENDLY ACTIONS ----------
async function giftMoney(npcId) {
    const player = GameState.player;
    if (!player) return;
    const npc = await loadNPC(npcId);
    if (!npc) return;

    const amountStr = prompt(`Enter amount of mon to give to ${npc.name} (you have ${player.wealth} mon):`);
    if (!amountStr) return;
    const amount = parseInt(amountStr);
    if (isNaN(amount) || amount <= 0 || amount > player.wealth) {
        alert('Invalid amount.');
        return;
    }

    player.wealth -= amount;
    npc.wealth += amount;

    const baseRel = amount / 5;
    const greedMod = npc.greed * 1.5;
    const relChange = Math.round(baseRel * greedMod);
    npc.adjustRelationship(player.id, relChange);

    const ctx = {
        npc: { name: npc.name, profession: npc.profession },
        player: { name: player.name },
        offering: `${amount} mon`,
        season: WorldClock.getCurrentContext().season,
        timeOfDay: WorldClock.getCurrentContext().timeOfDay
    };
    const narration = GME.generateNarration('social_gift_accept', ctx);
    GameState.log(narration);
    document.getElementById('log-panel').innerHTML += `\n${narration}`;

    await saveNPC(npc);
    await savePlayerToDB(player);
    showGameScreen();
    await TurnEngine.performAction('dialogue');
}

async function giftItem(npcId) {
    const player = GameState.player;
    if (!player) return;
    const npc = await loadNPC(npcId);
    if (!npc) return;

    if (player.inventory.length === 0) {
        alert('You have nothing to give.');
        return;
    }

    let itemList = 'Select item to gift:\n';
    player.inventory.forEach((inv, idx) => {
        // Use a simple synchronous fallback for item name if getItemDef not available
        itemList += `${idx + 1}. ${inv.itemId} (x${inv.quantity})\n`;
    });
    itemList += '0. Cancel';
    const choiceStr = prompt(itemList);
    const choice = parseInt(choiceStr);
    if (isNaN(choice) || choice === 0) return;
    const idx = choice - 1;
    if (idx < 0 || idx >= player.inventory.length) {
        alert('Invalid choice.');
        return;
    }

    const inv = player.inventory[idx];
    player.removeItem(inv.itemId, 1);
    if (!npc.inventory) npc.inventory = [];
    npc.inventory.push({ itemId: inv.itemId, quantity: 1 });

    const value = 5; // approximate base value, could be improved
    const relChange = Math.round(value / 5 * (npc.greed + 0.5));
    npc.adjustRelationship(player.id, relChange);

    const ctx = { npc: { name: npc.name }, offering: inv.itemId, season: WorldClock.getCurrentContext().season };
    const narration = GME.generateNarration('social_gift_accept', ctx);
    GameState.log(narration);
    document.getElementById('log-panel').innerHTML += `\n${narration}`;

    await saveNPC(npc);
    await savePlayerToDB(player);
    showGameScreen();
    await TurnEngine.performAction('dialogue');
}

async function doChore(npcId) {
    const player = GameState.player;
    if (!player) return;
    const npc = await loadNPC(npcId);
    if (!npc) return;

    await TurnEngine.performAction('chore', { npc });

