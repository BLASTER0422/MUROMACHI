async function makeRequest(npcId) {
    const player = GameState.player;
    if (!player) return;
    const npc = await loadNPC(npcId);
    if (!npc) return;

    const options = `What do you request from ${npc.name}?\n1. Ask for money (small loan)\n2. Ask for an item\n3. Ask for information\n0. Cancel`;
    const choiceStr = prompt(options);
    const choice = parseInt(choiceStr);
    if (isNaN(choice) || choice === 0) return;

    let success = false;
    let message = '';
    const rel = npc.getRelationship(player.id);

    switch (choice) {
        case 1:
            const amount = 10 + Math.floor(Math.random() * 20);
            success = rel > 10 || (npc.greed > 0.5 && rel > -10);
            if (success && npc.wealth >= amount) {
                npc.wealth -= amount;
                player.wealth += amount;
                npc.adjustRelationship(player.id, -3);
                message = `${npc.name} gives you ${amount} mon. "Don't forget to repay the kindness."`;
            } else {
                message = `"I cannot spare any coin right now."`;
            }
            break;
        case 2:
            if (npc.inventory.length === 0) {
                message = `"I have nothing to give."`;
            } else {
                const gift = npc.inventory[0];
                success = rel > 5;
                if (success) {
                    player.addItem(gift.itemId, 1);
                    npc.inventory.splice(0, 1);
                    message = `${npc.name} hands you a ${gift.itemId}.`;
                    npc.adjustRelationship(player.id, -2);
                } else {
                    message = `"I can't part with my belongings."`;
                }
            }
            break;
        case 3:
            success = true;
            message = GME.generateNPCDialogue(npc, player, 'gossip');
            break;
    }

    GameState.log(message);
    document.getElementById('log-panel').innerHTML += `\n${message}`;

    await saveNPC(npc);
    await savePlayerToDB(player);
    await TurnEngine.performAction('dialogue');
    showGameScreen();
}

async function recruitNPC(npcId) {
    const player = GameState.player;
    if (!player) return;
    const npc = await loadNPC(npcId);
    if (!npc || !npc.alive) return;

    if (npc.hired) {
        alert(`${npc.name} is already employed.`);
        return;
    }
    if (npc.isCaptive) {
        alert(`${npc.name} is currently a captive.`);
        return;
    }

    const mode = confirm(`Hire ${npc.name} as a permanent retainer? (Cancel for one-time task.)`);
    if (mode) {
        const wageStr = prompt(`Suggested daily wage (default: ${PROFESSIONS[npc.profession]?.wages || 5} mon):`);
        const wage = parseInt(wageStr) || (PROFESSIONS[npc.profession]?.wages || 5);
        if (wage > player.wealth / 2) {
            alert('You cannot afford that wage.');
            return;
        }
        npc.hired = true;
        npc.employerId = player.id;
        npc.hireMode = 'permanent';
        npc.wage = wage;
        player.followers.push(npc.npcId);
        GameState.log(`${npc.name} agrees to serve you as a retainer for ${wage} mon per day.`);
    } else {
        const task = prompt('What task? (e.g., carry goods, forage, guard):');
        if (!task) return;
        const feeStr = prompt('Offer (mon):', '20');
        const fee = parseInt(feeStr) || 20;
        if (fee > player.wealth) { alert('Not enough money.'); return; }
        player.wealth -= fee;
        npc.wealth += fee;
        npc.hireMode = 'one-time';
        npc.hireTask = task;
        GameState.log(`You hire ${npc.name} for a one-time task: ${task}. Paid ${fee} mon.`);
    }

    npc.adjustRelationship(player.id, 10);
    await saveNPC(npc);
    await savePlayerToDB(player);
    showGameScreen();
    await TurnEngine.performAction('dialogue');
}

// ---------- AGGRESSIVE ACTIONS ----------
async function insultNPC(npcId) {
    const player = GameState.player;
    if (!player) return;
    const npc = await loadNPC(npcId);
    if (!npc) return;

    const relChange = -10 - Math.floor(Math.random() * 10);
    npc.adjustRelationship(player.id, relChange);

    const ctx = { npc: { name: npc.name }, player: { name: player.name } };
    const narration = GME.generateNarration('social_insult_react', ctx);
    GameState.log(narration);
    document.getElementById('log-panel').innerHTML += `\n${narration}`;

    if (npc.aggression > 0.7 && npc.combatSkill > 0) {
        GameState.log(`${npc.name} draws a weapon!`);
        await initiateCombat(npc);
    }

    await saveNPC(npc);
    await savePlayerToDB(player);
    showGameScreen();
    await TurnEngine.performAction('dialogue');
}

async function threatenNPC(npcId) {
    const player = GameState.player;
    if (!player) return;
    const npc = await loadNPC(npcId);
    if (!npc) return;

    const playerIntimidation = player.getSkillRank('kenjutsu') + player.getSkillRank('sojutsu') + (player.reputation.general / 10);
    const npcBravery = 10 - (npc.fear * 10) + (npc.combatSkill / 2);
    const success = playerIntimidation > npcBravery;

    let narration = '';
    if (success) {
        const offering = npc.wealth > 20 ? `${Math.floor(npc.wealth / 2)} mon` : (npc.inventory.length > 0 ? 'an item' : 'nothing but begs');
        narration = `You loom over ${npc.name}. They tremble and offer ${offering}.`;
        if (npc.wealth > 20) {
            const half = Math.floor(npc.wealth / 2);
            npc.wealth -= half;
            player.wealth += half;
            GameState.log(`Received ${half} mon.`);
        } else if (npc.inventory.length > 0) {
            const item = npc.inventory.shift();
            player.addItem(item.itemId, item.quantity);
            GameState.log(`Received ${item.itemId}.`);
        }
        npc.adjustRelationship(player.id, -15);
    } else {
        narration = `${npc.name} refuses to be cowed. They reach for their weapon!`;
        npc.adjustRelationship(player.id, -20);
        await initiateCombat(npc);
    }

    GameState.log(narration);
    await saveNPC(npc);
    await savePlayerToDB(player);
    showGameScreen();
    await TurnEngine.performAction('dialogue');
}

async function attackNPC(npcId) {
    const player = GameState.player;
    if (!player) return;
    const npc = await loadNPC(npcId);
    if (!npc) return;

    GameState.log(`You attack ${npc.name}!`);
    await initiateCombat(npc);
