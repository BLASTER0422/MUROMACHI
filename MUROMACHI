                    { text: "Every promising leaf turns out to be worthless. You return empty-handed.", weight: 2 }
                ],
                huntSuccess: [
                    { text: "Your patience is rewarded. A {animal} wanders into range, and your strike is true.", weight: 3 },
                    { text: "You track the {animal} through the underbrush and bring it down with a clean shot.", weight: 2 }
                ],
                huntFail: [
