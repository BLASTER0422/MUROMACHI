}

async function kidnapNPC(npcId) {
    const player = GameState.player;
    if (!player) return;
    const npc = await loadNPC(npcId);
    if (!npc) return;

    if (npc.combatSkill < 1) {
        GameState.log(`${npc.name} is defenseless. You easily subdue them.`);
        npc.isCaptive = true;
        npc.captorId = player.id;
        npc.captureDate = WorldClock.getCurrentContext().year * 360 + WorldClock.getCurrentContext().month * 30 + WorldClock.getCurrentContext().day;
        npc.adjustRelationship(player.id, -50);
        player.followers.push(npc.npcId);
        await saveNPC(npc);
        await savePlayerToDB(player);
        showGameScreen();
    } else {
        GameState.log(`${npc.name} fights back! You must defeat them to capture.`);
        const outcome = await executeCombat(player, npc, false);
        if (outcome === 'win') {
            npc.isCaptive = true;
            npc.captorId = player.id;
            npc.captureDate = WorldClock.getCurrentContext().year * 360 + WorldClock.getCurrentContext().month * 30 + WorldClock.getCurrentContext().day;
            npc.adjustRelationship(player.id, -60);
            player.followers.push(npc.npcId);
            GameState.log(`${npc.name} is bound and captured.`);
            await saveNPC(npc);
            await savePlayerToDB(player);
        } else {
            GameState.log(`${npc.name} escapes or defeats you.`);
        }
    }
}

// ---------- COMPACT COMBAT (will be fully replaced by CombatEngine in Chunk 9) ----------
async function initiateCombat(enemyNPC) {
    const player = GameState.player;
    if (!player || !player.isAlive) return;
    await executeCombat(player, enemyNPC, false);
}

async function executeCombat(player, enemy, isAmbush) {
    const playerWeapon = player.equipped.weapon;
    const playerSkill = playerWeapon ? player.getSkillRank(getWeaponSkill(playerWeapon)) : player.getSkillRank('jujutsu');
    const enemySkill = enemy.combatSkill;
    const combatLog = [];
    let playerMorale = 100;
    let enemyMorale = 100;
    let round = 0;
    let winner = null;

    while (player.health > 0 && enemy.health > 0 && round < 20) {
        round++;
        const playerRoll = Math.random() * 100 + playerSkill * 5;
        const enemyDefense = enemySkill * 3 + 30;
        if (playerRoll > enemyDefense) {
            const dmg = 10 + Math.floor(Math.random() * 15) + playerSkill;
            enemy.health -= dmg;
            enemyMorale -= 10;
            combatLog.push(GME.generateNarration('combat_hit', { enemy: enemy.name, weapon: playerWeapon || 'fists', ground: 'earth' }));
        } else {
            combatLog.push(GME.generateNarration('combat_miss', { enemy: enemy.name, weapon: playerWeapon || 'fists' }));
        }

        if (enemy.health > 0) {
            const enemyRoll = Math.random() * 100 + enemySkill * 5;
            const playerDefense = playerSkill * 3 + 30;
            if (enemyRoll > playerDefense) {
                const dmg = 10 + Math.floor(Math.random() * 15) + enemySkill;
                player.health -= dmg;
                playerMorale -= 10;
                combatLog.push(GME.generateNarration('combat_enemyHit', { enemy: enemy.name, enemyWeapon: enemy.equippedWeapon || 'weapon' }));
            } else {
                combatLog.push(GME.generateNarration('combat_enemyMiss', { enemy: enemy.name }));
            }
        }

        if (enemy.health < 50 && enemyMorale < 30) {
            const yieldChance = getYieldChance(enemy.category);
            if (Math.random() < yieldChance) {
                combatLog.push(GME.generateNarration('combat_yield', { enemy: enemy.name }));
                const offer = generateYieldOffer(enemy);
                if (offer) {
                    combatLog.push(`${enemy.name} offers: ${offer}.`);
                    applyYieldOffer(player, enemy, offer);
                }
                winner = 'win_yield';
                break;
            }
        }

        if (enemy.fear > 0.7 && enemyMorale < 40 && Math.random() < 0.3) {
            combatLog.push(GME.generateNarration('combat_flee', { enemy: enemy.name }));
            winner = 'enemy_flee';
            break;
        }
    }

    if (!winner) {
        if (player.health <= 0) winner = 'lose';
        else if (enemy.health <= 0) {
            winner = 'win';
            enemy.alive = false;
            combatLog.push(GME.generateNarration('combat_kill', { enemy: enemy.name, enemyClass: enemy.category, ground: 'bloodstained earth', clan: enemy.faction || 'unknown' }));
        } else winner = 'draw';
    }

    for (const line of combatLog) GameState.log(line);
    document.getElementById('log-panel').innerHTML += `\n--- Combat Ended ---\n`;

    if (winner === 'win' || winner === 'win_yield') {
        if (enemy.wealth > 0) { player.wealth += enemy.wealth; GameState.log(`Found ${enemy.wealth} mon.`); enemy.wealth = 0; }
        for (const inv of enemy.inventory) { player.addItem(inv.itemId, inv.quantity); GameState.log(`Took ${inv.itemId} x${inv.quantity}.`); }
        enemy.inventory = [];
    } else if (winner === 'lose') {
        if (player.health <= 0) player.die('combat wounds');
    }

    await saveNPC(enemy);
    await savePlayerToDB(player);
    return winner;
}

function getYieldChance(npcCategory) {
    switch (npcCategory) {
        case 'commoner': return 0.7;
        case 'merchant': return 0.6;
        case 'outlaw': return 0.25;
        case 'samurai': return 0.15;
        default: return 0.4;
    }
}

function generateYieldOffer(enemy) {
    if (enemy.wealth > 20) return `${Math.floor(enemy.wealth * 0.6)} mon`;
    if (enemy.inventory.length > 0) return `their ${enemy.inventory[0].itemId}`;
    return null;
}

function applyYieldOffer(player, enemy, offer) {
    if (offer.includes('mon')) {
        const amount = parseInt(offer);
        if (!isNaN(amount) && enemy.wealth >= amount) {
            enemy.wealth -= amount;
            player.wealth += amount;
        }
    } else {
        if (enemy.inventory.length > 0) {
            const inv = enemy.inventory.shift();
            player.addItem(inv.itemId, inv.quantity);
        }
    }
}

function getWeaponSkill(weaponItemId) {
    switch (weaponItemId) {
        case 'item_katana': return 'kenjutsu';
        case 'item_yari': return 'sojutsu';
        case 'item_bow': return 'kyujutsu';
        default: return 'jujutsu';
    }
}


