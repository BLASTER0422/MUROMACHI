// ---------- PLAYER CHARACTER CLASS ----------
class PlayerCharacter {
    constructor(data = {}) {
        this.id = data.id || uuid();
        this.name = data.name || 'Traveler';
        this.age = data.age || 20;
        this.gender = data.gender || 'male';
        this.origin = data.origin || 'wanderer';
        this.birthYear = data.birthYear || (1380 - this.age);
        this.birthMonth = data.birthMonth || 1;
        this.birthDay = data.birthDay || 1;
        this.isAlive = true;
        this.deathCause = null;

        this.wealth = data.wealth || 50;
        this.hunger = data.hunger || 80;
        this.thirst = data.thirst || 90;
        this.fatigue = data.fatigue || 10;
        this.health = data.health || 100;

        this.skills = {};
        ALL_SKILLS.forEach(s => { this.skills[s.key] = data.skills?.[s.key] || 0; });

        this.inventory = data.inventory || [];
        this.equipped = {
            weapon: null,
            armor: null,
            carryItem: null
        };
        if (data.equipped) Object.assign(this.equipped, data.equipped);

        this.reputation = {
            local: data.reputation?.local || {},
            clan: data.reputation?.clan || {},
            general: data.reputation?.general || 0
        };

        this.injuries = data.injuries || [];
        this.locationId = data.locationId || 'shimosa_kogane';
        this.activeShelter = data.activeShelter || false;
        this.followers = data.followers || [];
        this.spouseId = data.spouseId || null;
        this.childrenIds = data.childrenIds || [];
        this.bounty = data.bounty || 0;
    }

    getMaxCarry() {
        let capacity = CARRY_CONFIG.base;
        if (this.equipped.carryItem) {
            const cfg = Object.values(CARRY_CONFIG).find(c => c.itemId === this.equipped.carryItem);
            if (cfg) capacity = cfg.capacity;
        }
        return capacity;
    }

    getCurrentWeight() {
        let total = 0;
        for (const inv of this.inventory) {
            // Synchronous fallback – itemDef might not be available, but we can use a default weight of 1.
            total += (inv.weight || 1) * (inv.quantity || 1);
        }
        return total;
    }

    isOverEncumbered() {
        return this.getCurrentWeight() > this.getMaxCarry();
    }

    getSpeedModifier() {
        let mod = 1.0;
        if (this.equipped.carryItem) {
            const cfg = Object.values(CARRY_CONFIG).find(c => c.itemId === this.equipped.carryItem);
            if (cfg) mod = cfg.speedMod;
        }
        if (this.isOverEncumbered()) mod *= 0.7;
        if (this.fatigue > 70) mod *= 0.8;
        if (this.fatigue > 90) mod *= 0.6;
        if (this.health < 30) mod *= 0.7;
        return Math.max(0.2, mod);
    }

    updateSurvival(minutes, actionType) {
        const hungerDecay = 0.05 * minutes;
        const thirstDecay = 0.06 * minutes;
        this.hunger = Math.max(0, this.hunger - hungerDecay);
        this.thirst = Math.max(0, this.thirst - thirstDecay);
        let fatigueGain = 0.03 * minutes;
        if (['combat_round', 'hunt', 'travel_1_ri', 'craft_large'].includes(actionType)) fatigueGain *= 1.5;
        this.fatigue = Math.min(100, this.fatigue + fatigueGain);
        if (this.hunger <= 0) this.adjustHealth(-2);
        if (this.thirst <= 0) this.adjustHealth(-3);
        if (this.fatigue >= 100) { this.adjustHealth(-1); this.fatigue = 100; }
    }

    eat(foodAmount, nutritionValue = 10) {
        this.hunger = Math.min(100, this.hunger + nutritionValue * foodAmount);
    }

    drink(amount = 1) {
        this.thirst = Math.min(100, this.thirst + 15 * amount);
    }

    rest(hours) {
        this.fatigue = Math.max(0, this.fatigue - hours * 8);
    }

    adjustHealth(amount) {
        this.health = Math.max(0, Math.min(100, this.health + amount));
        if (this.health <= 0) this.die('starvation or wounds');
    }

    adjustFatigue(amount) {
        this.fatigue = Math.max(0, Math.min(100, this.fatigue + amount));
    }

    addItem(itemId, quantity = 1) {
        const existing = this.inventory.find(i => i.itemId === itemId);
        if (existing) { existing.quantity += quantity; }
        else { this.inventory.push({ itemId, quantity }); }
    }

    removeItem(itemId, quantity = 1) {
        const idx = this.inventory.findIndex(i => i.itemId === itemId);
        if (idx === -1) return false;
        const inv = this.inventory[idx];
        if (inv.quantity <= quantity) { this.inventory.splice(idx, 1); }
        else { inv.quantity -= quantity; }
        return true;
    }

    hasItem(itemId, quantity = 1) {
        const inv = this.inventory.find(i => i.itemId === itemId);
        return inv && inv.quantity >= quantity;
    }

    getItemCount(itemId) {
        const inv = this.inventory.find(i => i.itemId === itemId);
        return inv ? inv.quantity : 0;
    }

    getSkillRank(skillKey) {
        return this.skills[skillKey] || 0;
    }

    canUseSkill(skillKey, minRank = 1) {
        return this.getSkillRank(skillKey) >= minRank;
    }

    die(cause = 'unknown causes') {
        this.isAlive = false;
        this.deathCause = cause;
        GameState.log(`\n\n===== YOU HAVE DIED: ${cause} =====`);
    }

    toJSON() {
        return {
            id: this.id, name: this.name, age: this.age, gender: this.gender, origin: this.origin,
            birthYear: this.birthYear, birthMonth: this.birthMonth, birthDay: this.birthDay,
            isAlive: this.isAlive, deathCause: this.deathCause,
            wealth: this.wealth, hunger: this.hunger, thirst: this.thirst, fatigue: this.fatigue, health: this.health,
            skills: this.skills, inventory: this.inventory, equipped: this.equipped,
            reputation: this.reputation, injuries: this.injuries, locationId: this.locationId,
            activeShelter: this.activeShelter, followers: this.followers,
            spouseId: this.spouseId, childrenIds: this.childrenIds, bounty: this.bounty
        };
    }

    static fromJSON(data) {
        return new PlayerCharacter(data);
    }
}


