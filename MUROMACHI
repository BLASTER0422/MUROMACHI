        const tx = db.transaction(STORES.items, 'readonly');
        const store = tx.objectStore(STORES.items);
        const item = await new Promise(res => { const req = store.get(itemId); req.onsuccess = () => res(req.result); });
        return item || { weight: 1, name: itemId };
    }
};


