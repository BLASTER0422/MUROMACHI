    document.getElementById('main-content').innerHTML += exploreHTML;
    document.getElementById('action-panel').innerHTML = '<button onclick="showGameScreen()">← Back</button>';
}

async function wildAction(action, terrain) {
    const player = GameState.player;
    if (!player) return;
    const weather = GameState.currentWeather || 'clear';
    let narration = '';
    let timeCost = 0;
    let success = false;
    let foundItem = null;
    let foundQty = 0;

    switch (action) {
        case 'forage':
            timeCost = TurnEngine.timeCosts.forage;
            const skillRank = player.getSkillRank('somoku');
            const roll = Math.random() * 100;
            success = roll < 30 + skillRank * 6;
            if (success) {
                const forageItems = terrain === 'coast' ? [{ id: 'item_dried_fish', name: 'edible shellfish', qty: 1 + Math.floor(Math.random() * 3) }] : [
                    { id: 'item_medicine_herb', name: 'medicinal herbs', qty: 1 + Math.floor(Math.random() * 2) },
                    { id: 'item_daikon_bunch', name: 'wild daikon', qty: 2 + Math.floor(Math.random() * 4) },
                    { id: 'item_millet_bag', name: 'wild grains', qty: 1 + Math.floor(Math.random() * 2) }
                ];
                const pick = forageItems[Math.floor(Math.random() * forageItems.length)];
                foundItem = pick.id; foundQty = pick.qty;
                player.addItem(foundItem, foundQty);
                narration = GME.generateNarration('wilderness_forage_success', { terrain, foundItem: pick.name, landmark: terrain === 'forest' ? 'fallen log' : terrain === 'coast' ? 'rocky pool' : 'sunlit clearing', season: WorldClock.getCurrentContext().season });
            } else { narration = GME.generateNarration('wilderness_forage_fail', { terrain }); }
            break;
        case 'hunt':
            timeCost = TurnEngine.timeCosts.hunt;
            const huntSkill = player.getSkillRank('shuryo');
            const bowSkill = player.equipped?.weapon === 'item_bow' ? player.getSkillRank('kyujutsu') : 0;
            success = Math.random() * 100 < 20 + Math.max(huntSkill, bowSkill) * 7;
            if (success) {
                const huntItems = terrain === 'mountain' ? [{ id: 'item_dried_fish', name: 'mountain hare', qty: 1 }] : [{ id: 'item_dried_fish', name: 'wild fowl', qty: 1 + Math.floor(Math.random() * 2) }];
                const pick = huntItems[Math.floor(Math.random() * huntItems.length)];
                foundItem = pick.id; foundQty = pick.qty;
                player.addItem(foundItem, foundQty);
                narration = GME.generateNarration('wilderness_hunt_success', { animal: pick.name, terrain });
            } else { narration = GME.generateNarration('wilderness_hunt_fail', { animal: ['deer', 'boar', 'hare'][Math.floor(Math.random() * 3)], terrain }); }
            break;
        case 'fish':
            timeCost = TurnEngine.timeCosts.fish;
            const fishSkill = player.getSkillRank('suisan');
            success = Math.random() * 100 < 35 + fishSkill * 6;
            if (success) {
                const fishTypes = terrain === 'coast' ? ['sea bream', 'bonito', 'mackerel'] : ['carp', 'eel', 'trout'];
                const pick = fishTypes[Math.floor(Math.random() * fishTypes.length)];
                foundItem = 'item_dried_fish'; foundQty = 1 + Math.floor(Math.random() * 3);
                player.addItem(foundItem, foundQty);
                narration = GME.generateNarration('wilderness_fish_success', { fish: pick });
            } else { narration = 'You cast your line and wait, but the waters yield nothing today.'; }
            break;
        case 'camp':
            timeCost = TurnEngine.timeCosts.rest_short;
            const fireSkill = player.getSkillRank('karyu');
            success = Math.random() * 100 < 50 + fireSkill * 5;
            if (success) {
                player.activeShelter = true;
                narration = GME.generateNarration('wilderness_camp_success', { weather });
                player.rest(1); player.adjustFatigue(-10);
            } else { narration = GME.generateNarration('wilderness_camp_fail', { weather }); player.adjustHealth(-3); }
            break;
        case 'shelter':
            timeCost = TurnEngine.timeCosts.craft_medium;
            const carpSkill = player.getSkillRank('daiku');
            success = Math.random() * 100 < 30 + carpSkill * 6;
            if (success) { player.activeShelter = true; narration = 'Using branches and thatch, you construct a sturdy lean-to. It will protect you from the elements for several nights.'; }
            else { narration = 'You attempt to build a shelter, but the materials are poor. It offers little protection.'; player.activeShelter = true; }
            break;
    }

    await TurnEngine.performAction(action, { terrain, timeOverride: timeCost });
    GameState.log(narration);
    document.getElementById('log-panel').scrollTop = document.getElementById('log-panel').scrollHeight;
    const main = document.getElementById('main-content');
    main.innerHTML += `<p style="color:var(--accent);">${narration}</p>`;
    if (foundItem && foundQty > 0) main.innerHTML += `<p style="color:var(--gold);">+ ${foundQty}x item acquired.</p>`;
    showGameScreen();
}


