async function constructBuilding(settlementId, buildingType) {
    const settlement = await loadSettlement(settlementId);
    if (!settlement) return;
    const player = GameState.player;
    const bld = BUILDING_TYPES[buildingType];
    if (!bld) return;
    if (!player.canUseSkill(bld.skill, bld.minRank)) { alert('Lack skill.'); return; }
    if (!checkMaterials(player, bld.cost)) { alert('Missing materials.'); return; }

    for (const [itemId, qty] of Object.entries(bld.cost)) {
        player.removeItem(itemId, qty);
    }

    settlement.buildings.push({
        buildingType: buildingType,
        name: bld.name,
        level: 1,
        condition: 100,
        assignedWorkers: [],
        builtYear: WorldClock.currentClock.year,
        builtMonth: WorldClock.currentClock.month
    });

    if (buildingType === 'watchtower') settlement.defenseRating += 2;
    if (buildingType === 'palisade_wall') { settlement.wallLevel = 1; settlement.defenseRating += 5; }

    await TurnEngine.performAction('craft_large', { timeOverride: bld.time });
    await saveSettlement(settlement);
    await savePlayerToDB(player);
    GameState.log(`${bld.name} constructed in ${settlement.name}.`);
    showSettlementManagementUI(settlement);
}

// ---------- ASSIGN WORKER ----------
async function assignWorker(settlementId, buildingIndex) {
    const settlement = await loadSettlement(settlementId);
    if (!settlement) return;
    const building = settlement.buildings[buildingIndex];
    if (!building) return;

    const residentNPCs = [];
    for (const npcId of settlement.residents) {
        const npc = await loadNPC(npcId);
        if (npc && npc.alive) residentNPCs.push(npc);
    }
    const unassigned = residentNPCs.filter(n => !settlement.buildings.some(b => b.assignedWorkers && b.assignedWorkers.includes(n.npcId)));
    if (unassigned.length === 0) {
        alert('No unassigned residents available.');
        return;
    }

    let choice = prompt(`Assign worker to ${building.name}. Choose:\n${unassigned.map((n, i) => `${i+1}. ${n.name} (${n.profession})`).join('\n')}\n0. Cancel`);
    const idx = parseInt(choice) - 1;
    if (isNaN(idx) || idx < 0 || idx >= unassigned.length) return;
    const npc = unassigned[idx];
    if (!building.assignedWorkers) building.assignedWorkers = [];
    building.assignedWorkers.push(npc.npcId);
    await saveSettlement(settlement);
    showSettlementManagementUI(settlement);
}

// ---------- UPGRADE BUILDING ----------
async function upgradeBuilding(settlementId, buildingIndex) {
    const settlement = await loadSettlement(settlementId);
    if (!settlement) return;
    const building = settlement.buildings[buildingIndex];
    if (!building) return;
    const bldDef = BUILDING_TYPES[building.buildingType];
    if (!bldDef) { alert('Cannot upgrade.'); return; }
    const player = GameState.player;
    const upgradeCost = Object.fromEntries(Object.entries(bldDef.cost).map(([k, v]) => [k, Math.ceil(v * 1.5)]));
    const skillNeeded = bldDef.minRank + 1;
    if (!checkMaterials(player, upgradeCost)) { alert('Missing materials.'); return; }
    if (player.getSkillRank(bldDef.skill) < skillNeeded) { alert('Skill too low.'); return; }

    for (const [itemId, qty] of Object.entries(upgradeCost)) {
        player.removeItem(itemId, qty);
    }
    building.level += 1;
    building.condition = 100;
    await TurnEngine.performAction('craft_medium', { timeOverride: Math.round(bldDef.time * 0.5) });
    await saveSettlement(settlement);
    await savePlayerToDB(player);
    GameState.log(`${building.name} upgraded to level ${building.level}.`);
    showSettlementManagementUI(settlement);
}

