    await new Promise(res => { tx.oncomplete = res; });
}

// ---------- SEED ALL LOCATIONS INTO DB ----------
async function seedAllLocations() {
    if (!db) return;
    const tx = db.transaction(STORES.locations, 'readwrite');
    const store = tx.objectStore(STORES.locations);
    const count = await new Promise(res => { const req = store.count(); req.onsuccess = () => res(req.result); });
    if (count > 20) return;

    for (const [provId, provData] of Object.entries(PROVINCE_LOCATIONS)) {
        for (const s of provData.settlements) {
            store.put({ locationId: s.id, name: s.name, type: s.type, province: provId, terrainTags: s.terrain, description: s.desc, population: s.pop, connectedLocations: [], parentLocation: provId });
        }
        for (const w of provData.wildNodes) {
            store.put({ locationId: w.id, name: w.name, type: 'wilderness', province: provId, terrainTags: w.terrain, description: w.desc, population: 0, connectedLocations: [], parentLocation: provId });
        }
    }

    for (const [provId, provData] of Object.entries(PROVINCE_LOCATIONS)) {
        store.put({ locationId: provId, name: provData.name, kanji: provData.kanji, type: 'province', province: provId, terrainTags: provData.terrainBase, description: `The province of ${provData.name}.`, connectedLocations: PROVINCE_BORDERS[provId] || [], parentLocation: null, population: provData.settlements.reduce((sum, s) => sum + (s.pop || 0), 0) });
    }

    const connectionMap = {};
    for (const conn of ROAD_CONNECTIONS) {
        if (!connectionMap[conn.from]) connectionMap[conn.from] = [];
        if (!connectionMap[conn.to]) connectionMap[conn.to] = [];
        connectionMap[conn.from].push(conn.to);
        connectionMap[conn.to].push(conn.from);
    }
    for (const [locId, connections] of Object.entries(connectionMap)) {
        const loc = await new Promise(res => { const req = store.get(locId); req.onsuccess = () => res(req.result); });
        if (loc) { loc.connectedLocations = [...new Set(connections)]; store.put(loc); }
    }

    await new Promise(res => { tx.oncomplete = res; });
}

