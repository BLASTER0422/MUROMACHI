    }

    // ---------- TEMPLATE SELECTION & FILLING ----------
    selectTemplate(categoryArray, context) {
        if (!categoryArray || categoryArray.length === 0) return '';
        const totalWeight = categoryArray.reduce((sum, t) => sum + (t.weight || 1), 0);
        let roll = Math.random() * totalWeight;
        for (const tpl of categoryArray) {
            roll -= (tpl.weight || 1);
            if (roll <= 0) return this.fillTemplate(tpl.text, context);
        }
        return this.fillTemplate(categoryArray[0].text, context);
    }

    fillTemplate(text, context) {
        return text.replace(/\{(\w+)\}/g, (match, key) => {
            return context[key] !== undefined ? context[key] : match;
        });
    }

    // ---------- MARKOV CHAINING ----------
    getNextCategory(chain, currentCategory) {
        const transitions = chain[currentCategory];
        if (!transitions || transitions.length === 0) return null;
        return transitions[Math.floor(Math.random() * transitions.length)];
    }

