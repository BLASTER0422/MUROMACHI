// ---------- FIND PATH BETWEEN LOCATIONS ----------
function findPath(fromId, toId) {
    if (fromId === toId) return { path: [], totalDistance: 0 };
    const visited = new Set();
    const queue = [[fromId, []]];
    while (queue.length > 0) {
        const [current, path] = queue.shift();
        if (current === toId) {
            let totalDist = 0;
            const fullPath = [...path, current];
            for (let i = 0; i < fullPath.length - 1; i++) {
                const conn = findConnection(fullPath[i], fullPath[i + 1]);
                if (conn) totalDist += conn.distance;
            }
            return { path: fullPath, totalDistance: totalDist };
        }
        if (visited.has(current)) continue;
        visited.add(current);
        const neighbors = getConnectedLocations(current);
        for (const neighbor of neighbors) {
            if (!visited.has(neighbor)) queue.push([neighbor, [...path, current]]);
        }
    }
    return null;
}

function findConnection(a, b) {
    return ROAD_CONNECTIONS.find(c => (c.from === a && c.to === b) || (c.from === b && c.to === a)) || null;
}

function getConnectedLocations(locId) {
    const connections = [];
    for (const conn of ROAD_CONNECTIONS) {
        if (conn.from === locId) connections.push(conn.to);
        if (conn.to === locId) connections.push(conn.from);
    }
    return [...new Set(connections)];
}

function getConnectionDistance(fromId, toId) {
    const conn = findConnection(fromId, toId);
    return conn ? conn.distance : null;
}

function getConnectionTerrain(fromId, toId) {
    const conn = findConnection(fromId, toId);
    return conn ? conn.terrain : 'plains';
}

// ---------- TRAVEL INTERFACE ----------
async function actionTravel() {
    const player = GameState.player;
    if (!player) return;
    const currentLoc = GameState.currentLocation || { locationId: 'shimosa_kogane', name: 'Kogane' };
    const currentId = currentLoc.locationId;
    const allLocs = await loadAllLocations();
    const connectedIds = getConnectedLocations(currentId);

    let travelHTML = `<h3>🗺️ Travel from ${currentLoc.name}</h3>`;
    travelHTML += `<p>You can travel to connected locations. Distance affects travel time.</p>`;
    travelHTML += `<div style="max-height:400px; overflow-y:auto;">`;

    if (connectedIds.length > 0) {
        travelHTML += '<h4>📌 Reachable Destinations</h4><ul>';
        for (const destId of connectedIds) {
            const dest = allLocs.find(l => l.locationId === destId);
            if (dest) {
                const dist = getConnectionDistance(currentId, destId) || 1;
                const terrain = getConnectionTerrain(currentId, destId) || 'plains';
                const speedMod = player.getSpeedModifier();
                const terrainMod = { plains: 1.0, hills: 0.75, mountain: 0.5, forest: 0.7, river: 0.6, coast: 0.85 }[terrain] || 1.0;
                const timeMin = Math.round((dist * TurnEngine.timeCosts.travel_1_ri) / (terrainMod * speedMod));
                const hours = Math.floor(timeMin / 60);
                const mins = timeMin % 60;
                const timeStr = hours > 0 ? `${hours}h ${mins}m` : `${mins}m`;
                travelHTML += `<li><strong>${dest.name}</strong> (${dest.type}) — ${dist} ri, ${terrain}<br><small>Est. travel: ${timeStr}</small><br><button onclick="executeTravel('${destId}')">🚶 Travel Here</button></li>`;
            }
        }
        travelHTML += '</ul>';
    } else {
        travelHTML += '<p>No direct paths from here. You may need to explore first.</p>';
    }

    travelHTML += `<pre style="font-size:10px; line-height:1.2; overflow-x:auto; background:#111108; padding:8px; margin-top:10px;">${generateTextMap(currentId)}</pre></div>`;
    document.getElementById('main-content').innerHTML += travelHTML;
    document.getElementById('action-panel').innerHTML = '<button onclick="showGameScreen()">← Back</button>';
}

async function executeTravel(destinationId) {
    const player = GameState.player;
    if (!player) return;
    const currentLoc = GameState.currentLocation;
    const currentId = currentLoc?.locationId;
    const dest = await getLocationById(destinationId);
    if (!dest) { GameState.log('That destination cannot be found.'); return; }

    const conn = findConnection(currentId, destinationId);
    if (!conn) { GameState.log('You cannot travel directly there.'); return; }

    const distance = conn.distance;
    const terrain = conn.terrain;
    const speedMod = player.getSpeedModifier();
    const terrainMods = { plains: 1.0, hills: 0.75, mountain: 0.5, forest: 0.7, river: 0.6, coast: 0.85 };
    const terrainMod = terrainMods[terrain] || 1.0;
    let totalTime = Math.round((distance * TurnEngine.timeCosts.travel_1_ri) / (terrainMod * speedMod));

    const weather = GameState.currentWeather || 'clear';
    if (['rain', 'snow', 'storm'].includes(weather)) totalTime = Math.round(totalTime * 1.3);

    const startNarration = GME.generateNarration('travel_start', {
        player: { name: player.name },
        origin: currentLoc.name,
        destination: dest.name,
        road: terrain === 'mountain' ? 'mountain path' : terrain === 'coast' ? 'coastal road' : 'dirt road',
        sky: weather === 'clear' ? 'bright' : 'overcast',
        season: WorldClock.getCurrentContext().season
    });
    GameState.log(startNarration);
    document.getElementById('log-panel').scrollTop = document.getElementById('log-panel').scrollHeight;

    await TurnEngine.performAction('travel_1_ri', { terrain, distance: totalTime / TurnEngine.timeCosts.travel_1_ri });

    const progressNarration = GME.generateNarration('travel_progress', {
        road: terrain === 'mountain' ? 'steep trail' : 'well-worn road',
        scenery: terrain === 'mountain' ? 'rocky peaks' : terrain === 'coast' ? 'the endless sea' : 'familiar countryside',
        landmark: ['an ancient pine', 'a roadside shrine', 'a weathered milestone', 'a small stream'][Math.floor(Math.random() * 4)],
        seasonalDetail: GME.fillTemplate(GME.templates.seasonalDetail[WorldClock.getCurrentContext().season] || '', {}),
        weather: weather,
        ground: terrain
    });
    GameState.log(progressNarration);

    const encounterRoll = Math.random();
    if (encounterRoll < 0.25) {
        const encounterTypes = ['bandit', 'beast', 'friendly', 'scout'];
        const encounterType = encounterTypes[Math.floor(Math.random() * encounterTypes.length)];
        let encNarration = '';
        switch (encounterType) {
            case 'bandit': encNarration = '⚠️ Figures emerge from the shadows — bandits! They demand your valuables.'; break;
            case 'beast': encNarration = `⚠️ A ${['wild boar', 'wolf', 'angry bear'][Math.floor(Math.random() * 3)]} blocks the path!`; break;
            case 'friendly': encNarration = '👤 A fellow traveler shares the road briefly. You exchange news.'; break;
            case 'scout': encNarration = '👤 A lone figure watches from a distance, then disappears. A scout, perhaps.'; break;
        }
        GameState.log(encNarration);
    }

    const arrivalNarration = GME.generateNarration('travel_arrive', {
        destination: dest.name,
        distance: distance,
        timeOfDay: WorldClock.getCurrentContext().timeOfDay,
        season: WorldClock.getCurrentContext().season,
        impression: dest.description || 'Its rooftops cluster beneath the watchful sky.',
        sky: weather === 'clear' ? 'bright' : 'grey'
    });
    GameState.log(arrivalNarration);

    GameState.currentLocation = dest;
    player.locationId = destinationId;
    document.getElementById('location-display').textContent = dest.name;
    WorldClock.updateStatusBar();
    showGameScreen();
}

