// ---------- QUEST ARCHETYPES ----------
const QUEST_ARCHETYPES = {
    fetch: { name: 'Fetch', description: 'Bring an item to the quest giver.', objective: 'fetch' },
    kill: { name: 'Slay', description: 'Defeat a dangerous beast or bandit.', objective: 'kill' },
    deliver: { name: 'Deliver', description: 'Take an item to another location.', objective: 'deliver' },
    protect: { name: 'Protect', description: 'Guard a person or location for a time.', objective: 'protect' },
    investigate: { name: 'Investigate', description: 'Discover the truth behind a rumor.', objective: 'investigate' },
    negotiate: { name: 'Negotiate', description: 'Mediate a dispute between parties.', objective: 'negotiate' }
};

// ---------- QUEST CLASS ----------
class Quest {
    constructor(data = {}) {
        this.questId = data.questId || uuid();
        this.title = data.title || 'A Simple Task';
        this.description = data.description || '';
        this.archetype = data.archetype || 'fetch';
        this.giverId = data.giverId || null;
        this.ownerId = data.ownerId || (GameState.player ? GameState.player.id : null);
        this.status = data.status || 'active'; // active, completed, failed
        this.objectives = data.objectives || [];
        this.rewards = data.rewards || { mon: 10, reputation: 5, items: [] };
        this.deadlineTurn = data.deadlineTurn || null;
        this.createdTurn = data.createdTurn || (WorldClock.getCurrentContext().year * 360 + WorldClock.getCurrentContext().day);
        this.completedTurn = data.completedTurn || null;
    }

    isExpired() {
        if (!this.deadlineTurn) return false;
        const current = WorldClock.getCurrentContext().year * 360 + WorldClock.getCurrentContext().day;
        return current > this.deadlineTurn;
    }

    complete(player) {
        this.status = 'completed';
        this.completedTurn = WorldClock.getCurrentContext().year * 360 + WorldClock.getCurrentContext().day;
        if (this.rewards.mon) player.wealth += this.rewards.mon;
        if (this.rewards.reputation) player.reputation.general += this.rewards.reputation;
        if (this.rewards.items) {
            this.rewards.items.forEach(it => player.addItem(it.itemId, it.quantity));
        }
        GameState.log(`Quest completed: ${this.title}. Rewards earned.`);
    }

    fail(reason = '') {
        this.status = 'failed';
        GameState.log(`Quest failed: ${this.title}. ${reason}`);
    }

    toJSON() {
        return { ...this };
    }

    static fromJSON(data) {
        return new Quest(data);
    }
}

// ---------- QUEST GENERATOR ----------
const QuestGenerator = {
    async generateQuestForNPC(npcId, player) {
        const npc = await loadNPC(npcId);
        if (!npc || !npc.alive) return null;
        const archetypeKeys = Object.keys(QUEST_ARCHETYPES);
        const archKey = archetypeKeys[Math.floor(Math.random() * archetypeKeys.length)];
        const arch = QUEST_ARCHETYPES[archKey];
        let title = '';
        let description = '';
        let objectives = [];
        let rewards = { mon: 10 + Math.floor(Math.random() * 30), reputation: 5 + Math.floor(Math.random() * 10), items: [] };
        const loc = await getLocationById(npc.locationId);
        const locName = loc ? loc.name : 'the area';

        switch (archKey) {
            case 'fetch': {
                const itemNeeded = ['item_medicine_herb', 'item_dried_fish', 'item_iron_ingot', 'item_sake_flask'][Math.floor(Math.random() * 4)];
                const itemName = (await GameState.getItemDef(itemNeeded))?.name || itemNeeded;
                title = `Gather ${itemName}`;
                description = `${npc.name} needs ${itemName}. Bring it back for a reward.`;
                objectives = [{ type: 'fetch', target: itemNeeded, quantity: 1, current: 0 }];
                break;
            }
            case 'kill': {
                const beast = ['wild boar', 'mad wolf', 'angry bear', 'bandit leader'][Math.floor(Math.random() * 4)];
                title = `Slay the ${beast}`;
                description = `A ${beast} has been terrorizing ${locName}. ${npc.name} asks you to eliminate it.`;
                objectives = [{ type: 'kill', target: beast, quantity: 1, current: 0 }];
                rewards.mon += 20;
                break;
            }
            case 'deliver': {
                const destSettlement = await this.getRandomSettlementExcluding(npc.locationId);
                const item = ['item_silk_bolt', 'item_charcoal_bundle', 'item_axe'][Math.floor(Math.random() * 3)];
                const itemName = (await GameState.getItemDef(item))?.name || item;
                title = `Deliver ${itemName}`;
                description = `Take this ${itemName} to ${destSettlement ? destSettlement.name : 'another settlement'} for ${npc.name}.`;
                objectives = [{ type: 'deliver', target: destSettlement ? destSettlement.locationId : 'unknown', item: item, quantity: 1 }];
                break;
            }
            case 'protect': {
                title = 'Guard Duty';
                description = `${npc.name} needs protection while traveling to ${locName}. Stay with them for a day.`;
                objectives = [{ type: 'protect', target: npcId, hours: 12 }];
                break;
            }
            case 'investigate': {
                title = 'Strange Rumors';
                description = `Investigate rumors of ${['a ghost', 'smugglers', 'hidden treasure', 'a secret meeting'][Math.floor(Math.random() * 4)]} near ${locName}.`;
                objectives = [{ type: 'investigate', target: npc.locationId, clues: 3 }];
                break;
            }
            case 'negotiate': {
                const otherNPC = await this.getRandomNPC(npc.locationId, npcId);
                title = 'Mediate Dispute';
                description = `${npc.name} and ${otherNPC ? otherNPC.name : 'another'} are feuding. Help them find peace.`;
                objectives = [{ type: 'negotiate', target: otherNPC ? otherNPC.npcId : 'unknown', agreement: false }];
                break;
            }
        }

        const quest = new Quest({
            title,
            description,
            archetype: archKey,
            giverId: npcId,
            objectives,
            rewards
        });
        return quest;
    },

    async getRandomSettlementExcluding(excludeId) {
        const allLocs = await loadAllLocations();
        const settlements = allLocs.filter(l => (l.type === 'town' || l.type === 'city' || l.type === 'village') && l.locationId !== excludeId);
        if (settlements.length === 0) return null;
        return settlements[Math.floor(Math.random() * settlements.length)];
    },

    async getRandomNPC(locationId, excludeId) {
        const npcs = await loadNPCsAtLocation(locationId);
        const filtered = npcs.filter(n => n.alive && n.npcId !== excludeId);
        if (filtered.length === 0) return null;
        return filtered[Math.floor(Math.random() * filtered.length)];
    }
};

