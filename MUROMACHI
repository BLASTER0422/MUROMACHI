<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Muromachi: Path of the Eight Provinces</title>
    <style>
        :root {
            --bg: #1a1a0f;
            --panel-bg: #2a2a1c;
            --text: #c0b090;
            --accent: #b85c38;
            --gold: #c9a74b;
            --border: #5a5a3a;
            --highlight: #f0e0c0;
            --danger: #a03020;
            --button-bg: #3a3a24;
            --button-hover: #4a4a30;
            --input-bg: #222215;
            --font-main: 'Georgia', 'Times New Roman', serif;
            --font-mono: 'Courier New', monospace;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--font-main);
            font-size: 16px;
            line-height: 1.5;
            max-width: 800px;
            margin: 0 auto;
            padding: 10px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        h1, h2, h3 { color: var(--accent); margin-bottom: 0.5em; }
        .panel {
            background: var(--panel-bg);
            border: 1px solid var(--border);
            padding: 15px;
            margin-bottom: 15px;
            border-radius: 4px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.5);
        }
        button, .btn {
            background: var(--button-bg);
            color: var(--text);
            border: 1px solid var(--border);
            padding: 8px 16px;
            cursor: pointer;
            font-family: var(--font-main);
            font-size: 14px;
            border-radius: 3px;
            transition: background 0.2s;
            margin: 2px;
        }
        button:hover, .btn:hover { background: var(--button-hover); }
        button:disabled { opacity: 0.5; cursor: not-allowed; }
        input, select, textarea {
            background: var(--input-bg);
            color: var(--text);
            border: 1px solid var(--border);
            padding: 5px 8px;
            font-family: var(--font-main);
            font-size: 14px;
            border-radius: 3px;
        }
        .flex-row { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
        .flex-col { display: flex; flex-direction: column; gap: 8px; }
        .hidden { display: none !important; }
        .log-text { white-space: pre-wrap; font-family: var(--font-mono); background: #111108; padding: 10px; border: 1px solid var(--border); max-height: 300px; overflow-y: auto; }
        .status-bar { display: flex; justify-content: space-between; background: var(--panel-bg); padding: 8px 15px; border-bottom: 1px solid var(--border); }
        @media (max-width: 600px) { body { padding: 5px; } }
    </style>
</head>
<body>
<div id="app-root">
    <div class="status-bar" id="status-bar">
        <span id="time-display">Year 1380, Mutsuki 1st, Hour of the Rat</span>
        <span id="location-display">Unknown</span>
        <span id="health-display">Healthy</span>
    </div>
    <div id="main-content" class="panel"></div>
    <div id="action-panel" class="panel"></div>
    <div id="log-panel" class="panel log-text"></div>
</div>

<script>
// ==================== MUROMACHI GAME ENGINE ====================
// No external APIs, fully offline. All data in IndexedDB.

const DB_NAME = 'MuromachiWorld';
const DB_VERSION = 1;
const STORES = {
    playerState: 'playerState',
    npcs: 'npcs',
    locations: 'locations',
    items: 'items',
    quests: 'quests',
    events: 'events',
    dialogueTrees: 'dialogueTrees',
    worldClock: 'worldClock',
    playerLog: 'playerLog',
    crimeRecords: 'crimeRecords',
    economy: 'economy',
    landProperties: 'landProperties',
    settlements: 'settlements'
};

function uuid() {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {
        const r = Math.random() * 16 | 0;
        return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
    });
}

function openDB() {
    return new Promise((resolve, reject) => {
        const request = indexedDB.open(DB_NAME, DB_VERSION);
        request.onupgradeneeded = (event) => {
            const db = event.target.result;
            if (!db.objectStoreNames.contains(STORES.playerState)) {
                db.createObjectStore(STORES.playerState, { keyPath: 'id' });
            }
            if (!db.objectStoreNames.contains(STORES.npcs)) {
                const npcStore = db.createObjectStore(STORES.npcs, { keyPath: 'npcId' });
                npcStore.createIndex('location', 'location', { unique: false });
                npcStore.createIndex('faction', 'faction', { unique: false });
                npcStore.createIndex('alive', 'alive', { unique: false });
            }
            if (!db.objectStoreNames.contains(STORES.locations)) {
                const locStore = db.createObjectStore(STORES.locations, { keyPath: 'locationId' });
                locStore.createIndex('type', 'type', { unique: false });
                locStore.createIndex('province', 'province', { unique: false });
            }
            if (!db.objectStoreNames.contains(STORES.items)) {
                const itemStore = db.createObjectStore(STORES.items, { keyPath: 'itemId' });
                itemStore.createIndex('category', 'category', { unique: false });
            }
            if (!db.objectStoreNames.contains(STORES.quests)) {
                db.createObjectStore(STORES.quests, { keyPath: 'questId' });
            }
            if (!db.objectStoreNames.contains(STORES.events)) {
                db.createObjectStore(STORES.events, { keyPath: 'eventId' });
            }
            if (!db.objectStoreNames.contains(STORES.dialogueTrees)) {
                db.createObjectStore(STORES.dialogueTrees, { keyPath: 'treeId' });
            }
            if (!db.objectStoreNames.contains(STORES.worldClock)) {
                db.createObjectStore(STORES.worldClock, { keyPath: 'id' });
            }
            if (!db.objectStoreNames.contains(STORES.playerLog)) {
                const logStore = db.createObjectStore(STORES.playerLog, { keyPath: 'logId', autoIncrement: true });
                logStore.createIndex('turn', 'turn', { unique: false });
            }
            if (!db.objectStoreNames.contains(STORES.crimeRecords)) {
                db.createObjectStore(STORES.crimeRecords, { keyPath: 'recordId' });
            }
            if (!db.objectStoreNames.contains(STORES.economy)) {
                db.createObjectStore(STORES.economy, { keyPath: 'locationId' });
            }
            if (!db.objectStoreNames.contains(STORES.landProperties)) {
                db.createObjectStore(STORES.landProperties, { keyPath: 'propertyId' });
            }
            if (!db.objectStoreNames.contains(STORES.settlements)) {
                db.createObjectStore(STORES.settlements, { keyPath: 'settlementId' });
            }
        };
        request.onsuccess = () => resolve(request.result);
        request.onerror = () => reject(request.error);
    });
}

async function bootstrapWorld(db) {
    const tx = db.transaction([STORES.locations, STORES.items, STORES.worldClock, STORES.economy], 'readwrite');
    const clockStore = tx.objectStore(STORES.worldClock);
    const existingClock = await new Promise(res => { const req = clockStore.get('clock'); req.onsuccess = () => res(req.result); });
    if (existingClock) { tx.abort(); return; }

    clockStore.put({ id: 'clock', year: 1380, month: 1, day: 1, hour: 5, season: 'spring', temperature: 8, era: 'Kōryaku 2 / Tenju 6' });

    const provinces = [
        { id: 'shimosa', name: 'Shimōsa', kanji: '下総国' },
        { id: 'hitachi', name: 'Hitachi', kanji: '常陸国' },
        { id: 'shimotsuke', name: 'Shimotsuke', kanji: '下野国' },
        { id: 'kozuke', name: 'Kōzuke', kanji: '上野国' },
        { id: 'musashi', name: 'Musashi', kanji: '武蔵国' },
        { id: 'kazusa', name: 'Kazusa', kanji: '上総国' },
        { id: 'awa', name: 'Awa', kanji: '安房国' },
        { id: 'sagami', name: 'Sagami', kanji: '相模国' }
    ];
    const locStore = tx.objectStore(STORES.locations);
    for (const prov of provinces) {
        locStore.add({ locationId: prov.id, name: prov.name, kanji: prov.kanji, type: 'province', province: prov.id, terrainTags: [], description: `The province of ${prov.name}.`, connectedLocations: [], parentLocation: null });
    }

    const sampleSettlements = [
        { locationId: 'shimosa_kogane', name: 'Kogane', type: 'town', province: 'shimosa', terrainTags: ['river'], description: 'A bustling town along the Tone River.' },
        { locationId: 'hitachi_mito', name: 'Mito', type: 'city', province: 'hitachi', terrainTags: ['coast'], description: 'Seat of the Satake clan.' },
        { locationId: 'musashi_edo', name: 'Edo', type: 'town', province: 'musashi', terrainTags: ['river','coast'], description: 'A growing port town.' },
        { locationId: 'sagami_kamakura', name: 'Kamakura', type: 'city', province: 'sagami', terrainTags: ['coast','hills'], description: 'Ancient shogunal capital.' },
        { locationId: 'shimotsuke_utsunomiya', name: 'Utsunomiya', type: 'town', province: 'shimotsuke', terrainTags: ['hills'], description: 'Famous for horses.' },
        { locationId: 'kozuke_takasaki', name: 'Takasaki', type: 'town', province: 'kozuke', terrainTags: ['river'], description: 'Trade hub.' },
        { locationId: 'kazusa_ichinomiya', name: 'Ichinomiya', type: 'town', province: 'kazusa', terrainTags: ['coast'], description: 'Shellfish and shrine.' },
        { locationId: 'awa_tateyama', name: 'Tateyama', type: 'town', province: 'awa', terrainTags: ['coast','mountain'], description: 'Peninsula’s end.' }
    ];
    for (const s of sampleSettlements) {
        locStore.add({ locationId: s.locationId, name: s.name, type: s.type, province: s.province, terrainTags: s.terrainTags, description: s.description, connectedLocations: [], parentLocation: s.province });
    }

    const econStore = tx.objectStore(STORES.economy);
    for (const s of sampleSettlements) {
        econStore.add({
            locationId: s.locationId,
            goods: {
                rice: { basePrice: 5, supply: 500, demand: 1.0 },
                millet: { basePrice: 3, supply: 300, demand: 0.8 },
                daikon: { basePrice: 2, supply: 200, demand: 0.9 },
                fish: { basePrice: 4, supply: 150, demand: 0.7 },
                sake: { basePrice: 12, supply: 80, demand: 0.6 },
                iron: { basePrice: 20, supply: 40, demand: 0.5 },
                silk: { basePrice: 35, supply: 25, demand: 0.4 },
                charcoal: { basePrice: 6, supply: 100, demand: 0.8 },
                pottery: { basePrice: 8, supply: 60, demand: 0.6 },
                tools: { basePrice: 15, supply: 45, demand: 0.7 },
                weapons: { basePrice: 30, supply: 20, demand: 0.3 }
            }
        });
    }

    const itemStore = tx.objectStore(STORES.items);
    const baseItems = [
        { itemId: 'item_rice_bag', name: 'Bag of Rice', category: 'food', perishable: true, weight: 5, baseValue: 5 },
        { itemId: 'item_millet_bag', name: 'Bag of Millet', category: 'food', perishable: true, weight: 4, baseValue: 3 },
        { itemId: 'item_daikon_bunch', name: 'Bunch of Daikon', category: 'food', perishable: true, weight: 1, baseValue: 2 },
        { itemId: 'item_dried_fish', name: 'Dried Fish', category: 'food', perishable: false, weight: 1, baseValue: 3 },
        { itemId: 'item_sake_flask', name: 'Flask of Sake', category: 'food', perishable: false, weight: 2, baseValue: 12 },
        { itemId: 'item_iron_ingot', name: 'Iron Ingot', category: 'material', perishable: false, weight: 10, baseValue: 20 },
        { itemId: 'item_silk_bolt', name: 'Bolt of Silk', category: 'material', perishable: false, weight: 2, baseValue: 35 },
        { itemId: 'item_charcoal_bundle', name: 'Bundle of Charcoal', category: 'material', perishable: false, weight: 8, baseValue: 6 },
        { itemId: 'item_axe', name: 'Woodcutter Axe', category: 'tool', perishable: false, weight: 8, baseValue: 15 },
        { itemId: 'item_hoe', name: 'Farming Hoe', category: 'tool', perishable: false, weight: 6, baseValue: 12 },
        { itemId: 'item_katana', name: 'Katana', category: 'weapon', perishable: false, weight: 4, baseValue: 50, skillReq: 'kenjutsu' },
        { itemId: 'item_yari', name: 'Yari (Spear)', category: 'weapon', perishable: false, weight: 5, baseValue: 30, skillReq: 'sojutsu' },
        { itemId: 'item_bow', name: 'Yumi (Bow)', category: 'weapon', perishable: false, weight: 3, baseValue: 40, skillReq: 'kyujutsu' },
        { itemId: 'item_medicine_herb', name: 'Healing Herb', category: 'medicine', perishable: true, weight: 0.5, baseValue: 8 }
    ];
    for (const item of baseItems) { itemStore.add(item); }

    await new Promise(res => { tx.oncomplete = res; });
}

let db; // global database handle – will be assigned by the final bootstrap
// No early initialization – all startup is done in Chunk 16 after all systems are defined.

// ==================== CHUNK 2: GAME MASTER ENGINE CORE ====================

class GameMasterEngine {
    constructor() {
        this.templates = this.buildTemplateLibrary();
        this.markovChains = this.buildMarkovChains();
        this.usedDialogue = new Map(); // Track recent dialogue per NPC to avoid repetition
    }

    // ---------- MASSIVE TEMPLATE LIBRARY ----------
    buildTemplateLibrary() {
        return {
            // ---- COMBAT ----
            combat: {
                opening: {
                    aggressive: [
                        { text: "You surge forward, {weapon} raised high, the fury of battle burning in your veins.", weight: 3 },
                        { text: "With a sharp kiai, you launch yourself at {enemy}, {weapon} cutting the air.", weight: 3 },
                        { text: "Rage guides your blade as you close the distance, feet pounding the {ground}.", weight: 2 }
                    ],
                    defensive: [
                        { text: "You settle into a guarded stance, {weapon} held ready, watching {enemy}'s every movement.", weight: 3 },
                        { text: "Patience. You circle {enemy} warily, waiting for the opening that will end this.", weight: 3 },
                        { text: "Your feet find solid {ground} as you brace yourself, letting {enemy} make the first mistake.", weight: 2 }
                    ],
                    evasive: [
                        { text: "Light on your feet, you dance away from {enemy}'s reach, seeking an angle.", weight: 3 },
