// Economy engine – updatePrices now uses dbGet/dbPut
EconomyEngine.getPrice = async function(locationId, goodKey) {
    const cacheKey = `${locationId}_${goodKey}`;
    if (this.priceCache[cacheKey] !== undefined) return this.priceCache[cacheKey];
    const econData = await dbGet(STORES.economy, locationId);
    if (econData?.goods?.[goodKey]) {
        const g = econData.goods[goodKey];
        const price = Math.max(1, Math.round(g.basePrice * (1 + g.demand * 0.5 - g.supply * 0.001)));
        this.priceCache[cacheKey] = price;
        return price;
    }
    const base = MARKET_GOODS[goodKey]?.basePrice || 5;
    this.priceCache[cacheKey] = base;
    return base;
};

EconomyEngine.getSupply = async function(locationId, goodKey) {
    const econData = await dbGet(STORES.economy, locationId);
    return econData?.goods?.[goodKey]?.supply ?? 100;
};

EconomyEngine.updatePrices = async function(locationId) {
    let econData = await dbGet(STORES.economy, locationId);
    if (!econData) {
        econData = { locationId, goods: {} };
        for (const [k, def] of Object.entries(MARKET_GOODS)) {
            econData.goods[k] = { basePrice: def.basePrice, supply: 100 + Math.floor(Math.random()*200), demand: 0.5 + Math.random()*0.5 };
        }
    }
    // ... (same fluctuation logic)
    const season = WorldClock.getCurrentContext().season;
    const events = GameState.activeEvents || [];
    for (const [k, def] of Object.entries(MARKET_GOODS)) {
        if (!econData.goods[k]) {
            econData.goods[k] = { basePrice: def.basePrice, supply: 100 + Math.floor(Math.random()*200), demand: 0.5 + Math.random()*0.5 };
        }
        const g = econData.goods[k];
        if (def.category === 'food' && def.perishable) {
            if (season === 'autumn') g.supply += 20;
            if (season === 'winter') g.supply -= 15;
            if (season === 'spring') g.demand += 0.1;
        }
        if (k === 'sake' && season === 'winter') g.demand += 0.2;
        if (k === 'charcoal' && season === 'winter') g.demand += 0.3;
        if (k === 'timber' && season === 'spring') g.demand += 0.15;
        for (const ev of events) {
            if (ev.type === 'drought' || ev.type === 'flood') if (def.category === 'food') g.supply -= 30;
            if (ev.type === 'war' || ev.type === 'bandit_raid') if (def.category === 'weapon' || k === 'iron_ingot') g.demand += 0.4;
            if (ev.type === 'merchant_caravan') g.supply += 25;
        }
        g.supply += Math.floor(Math.random()*10 - 5);
        g.demand += (Math.random()*0.1 - 0.05);
        g.supply = Math.max(5, Math.min(500, g.supply));
        g.demand = Math.max(0.1, Math.min(2.0, g.demand));
    }
    await dbPut(STORES.economy, econData);
    for (const k of Object.keys(this.priceCache)) if (k.startsWith(locationId + '_')) delete this.priceCache[k];
};

// Crime records
CrimeSystem.recordCrime = async function(crimeType, player, location, witnesses = []) {
    // same logic, just use dbPut for the record
    const severityMap = { insult:1, threaten:3, assault:5, kidnap:8, murder:10 };
    const severity = severityMap[crimeType] || 1;
    const province = location.province || 'shimosa';
    let reported = false;
    for (const w of witnesses) {
        if (!w.alive) continue;
        const rel = w.getRelationship(player.id);
        const fear = w.fear;
        const reportChance = Math.max(0.05, (1 - (rel + 100)/200) * (1 - fear*0.5));
        if (Math.random() < reportChance) { reported = true; break; }
    }
    const crimeRecord = {
        recordId: uuid(),
        crimeType, severity, province,
        locationId: location.locationId,
        perpetratorId: player.id, perpetratorName: player.name,
        turn: WorldClock.getCurrentContext().year*360 + WorldClock.getCurrentContext().day,
        reported, bounty: severity*10, resolved: false
    };
    await dbPut(STORES.crimeRecords, crimeRecord);
    player.reputation.general -= severity;
    player.bounty = (player.bounty||0) + crimeRecord.bounty;
    GameState.log(reported ? 'Witnesses report the crime...' : 'The crime goes unreported...');
    await savePlayerToDB(player);
};

