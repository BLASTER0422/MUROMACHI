// ---------- COMPLETE / FAIL QUEST LOGIC ----------
async function tryCompleteQuest(questId) {
    const quest = await loadQuest(questId);
    if (!quest || quest.status !== 'active') return false;
    const player = GameState.player;
    if (!player) return false;

    let allComplete = true;
    for (const obj of quest.objectives) {
        if (obj.type === 'fetch' && obj.current < obj.quantity) allComplete = false;
        if (obj.type === 'kill' && obj.current < obj.quantity) allComplete = false;
    }

    if (allComplete) {
        quest.complete(player);
        await saveQuest(quest);
        GameState.log(`Quest "${quest.title}" completed!`);
        return true;
    }
    return false;
}

// Hook into killing an enemy for "kill" quests
const origEndCombatQuest = CombatEngine.endCombat;
CombatEngine.endCombat = async function(result) {
    const combat = this.activeCombat;
    await origEndCombatQuest.call(this, result);
    if (combat && result === 'enemy_dead') {
        const enemy = combat.enemy;
        const player = GameState.player;
        if (!player) return;
        const quests = await loadPlayerQuests(player.id);
        for (const q of quests) {
            if (q.status !== 'active') continue;
            for (const obj of q.objectives) {
                if (obj.type === 'kill' && enemy.name.toLowerCase().includes(obj.target.toLowerCase())) {
                    obj.current++;
                    GameState.log(`Quest progress: ${q.title} — ${obj.target} slain (${obj.current}/${obj.quantity})`);
                    await saveQuest(q);
                    await tryCompleteQuest(q.questId);
                }
            }
        }
    }
};

// Hook into delivering items (when arriving at a location)
const origExecuteTravelQuest = executeTravel;
executeTravel = async function(destinationId) {
    await origExecuteTravelQuest(destinationId);
    const player = GameState.player;
    if (!player) return;
    const quests = await loadPlayerQuests(player.id);
    for (const q of quests) {
        if (q.status !== 'active') continue;
        for (const obj of q.objectives) {
            if (obj.type === 'deliver' && obj.target === destinationId && player.hasItem(obj.item, obj.quantity)) {
                player.removeItem(obj.item, obj.quantity);
                obj.current = 1;
                await saveQuest(q);
                GameState.log(`Delivered ${obj.item} for quest "${q.title}".`);
                await tryCompleteQuest(q.questId);
            }
        }
    }
};

