async function handlePlayerDeath() {
    const player = GameState.player;
    if (!player || player.isAlive) return;
    GameState.log(`\n\n===== ${player.name} has died — ${player.deathCause} =====`);

    let heir = null;
    if (player.childrenIds && player.childrenIds.length > 0) {
        for (const childId of player.childrenIds) {
            const child = await loadNPC(childId);
            if (child && child.alive && child.age >= 16) {
                if (!heir || child.age > heir.age) heir = child;
            }
        }
    }

    if (!heir) {
        document.getElementById('main-content').innerHTML = `
            <h2 style="color:var(--danger);">Death</h2>
            <p>${player.name} has passed away, leaving no heir to carry on the legacy.</p>
            <p>The settlement falls to ruin, and the story ends.</p>
            <button onclick="showTitleScreen()">Return to Title</button>
        `;
        document.getElementById('action-panel').innerHTML = '';
        GameState.player = null;
        return;
    }

    const heirNPC = heir;
    const newPlayer = new PlayerCharacter({
        id: heirNPC.npcId,
        name: heirNPC.name,
        age: heirNPC.age,
        gender: heirNPC.gender,
        origin: 'heir',
        birthYear: heirNPC.birthYear,
        birthMonth: heirNPC.birthMonth,
        skills: {},
        wealth: Math.floor(player.wealth * 0.7),
        inventory: [],
        locationId: player.locationId
    });

    newPlayer.reputation = {
        local: { ...player.reputation.local },
        clan: { ...player.reputation.clan },
        general: Math.floor(player.reputation.general * 0.7)
    };

    newPlayer.inventory = player.inventory.slice(0, Math.ceil(player.inventory.length * 0.7));

    const settlements = await getPlayerSettlements(player.id);
    for (const s of settlements) {
        s.founderId = newPlayer.id;
        await saveSettlement(s);
    }

    const parentSkills = Object.entries(player.skills).filter(([k, v]) => v >= 3);
    for (let i = 0; i < 3 && i < parentSkills.length; i++) {
        const [skillKey, skillVal] = parentSkills[i];
        newPlayer.skills[skillKey] = Math.max(1, skillVal - 2);
    }

    await savePlayerToDB(newPlayer);
    GameState.setPlayer(newPlayer);

    if (db) {
        const tx = db.transaction(STORES.npcs, 'readwrite');
        tx.objectStore(STORES.npcs).delete(heirNPC.npcId);
        await new Promise(res => { tx.oncomplete = res; });
    }

    GameState.log(`Your heir, ${newPlayer.name}, steps forward to continue the family legacy.`);
    document.getElementById('log-panel').scrollTop = document.getElementById('log-panel').scrollHeight;
    showGameScreen();
}

