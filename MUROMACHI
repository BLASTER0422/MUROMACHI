async function loadGame() {
    const player = await loadPlayerFromDB();
    if (!player) { alert('No save found.'); return; }
    GameState.setPlayer(player);
    GameState.currentLocation = await loadLocation(player.locationId);
    document.getElementById('location-display').textContent = GameState.currentLocation?.name || 'Unknown';
    WorldClock.updateStatusBar();
    document.getElementById('log-panel').innerHTML = '';
    GameState.log(`You resume your journey in ${GameState.currentLocation?.name || 'these lands'}.`);
    showGameScreen();
}

async function showDeleteScreen() {
    const main = document.getElementById('main-content');
    const player = await loadPlayerFromDB();
    if (!player) {
        main.innerHTML = '<h2>No Saved Game</h2><p>No save to delete.</p>';
        document.getElementById('action-panel').innerHTML = '<button onclick="showTitleScreen()">← Back</button>';
        return;
    }
    main.innerHTML = `
        <h2>🗑️ Delete Save</h2>
        <p>Are you certain? The journey of <strong>${player.name}</strong> will be lost forever.</p>
        <button onclick="deleteSave()" style="color:var(--danger);">Yes, Delete</button>
        <button onclick="showTitleScreen()">Cancel</button>
    `;
    document.getElementById('action-panel').innerHTML = '';
}

async function deleteSave() {
    if (!db) return;
    const tx = db.transaction(STORES.playerState, 'readwrite');
    const store = tx.objectStore(STORES.playerState);
    store.delete('player');
    await new Promise(res => { tx.oncomplete = res; });
    localStorage.removeItem('sessionPointer');
    GameState.player = null;
    GameState.currentLocation = null;
    document.getElementById('log-panel').innerHTML = 'Save deleted. The journey ends.';
    showTitleScreen();
}

