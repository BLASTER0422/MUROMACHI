async function dismissFollower(npcId) {
    const player = GameState.player;
    if (!player) return;
    const npc = await loadNPC(npcId);
    if (!npc) {
        player.followers = player.followers.filter(id => id !== npcId);
        await savePlayerToDB(player);
        actionFollowers();
        return;
    }
    const confirmDismiss = confirm(`Dismiss ${npc.name}? They may be upset.`);
    if (!confirmDismiss) return;
    if (npc.isCaptive) {
        npc.isCaptive = false;
        npc.captorId = null;
        npc.captureDate = null;
        npc.adjustRelationship(player.id, -10);
    } else {
